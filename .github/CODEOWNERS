# CODEOWNERS for the NVCF monorepo.
# All listed owners must be members of https://github.com/orgs/NVIDIA/teams/nvcf-dev.
# Order matters: the last matching pattern wins.
# Docs: https://docs.github.com/en/repositories/managing-your-repositorys-settings-and-features/customizing-your-repository/about-code-owners

# Default fallback for paths not otherwise matched.
*                                                       @NVIDIA/nvcf-dev

# GitHub config and workflows.
/.github/                                               @jmcnamee @mcamp

# This CODEOWNERS file.
/.github/CODEOWNERS                                     @NVIDIA/nvcf-admin

# Helm charts (deploy/helm/* tracks per-chart upstream repos).
/deploy/helm/                                           @jmcnamee

# Cassandra and OpenBao infrastructure charts.
/deploy/helm/cassandra/                                 @mikeyrcamp @nvjmcnamee @kferris-nvidia @along-2017 @vrv3814 @bvernon-nv
/deploy/helm/openbao/                                   @mikeyrcamp @nvjmcnamee @kferris-nvidia @along-2017 @vrv3814 @gsharma-nvidia @bvernon-nv

# Control-plane application charts.
/deploy/helm/admin-token-issuer-proxy/                  @jmcnamee @NVIDIA/nvcf-control-plane-dev
/deploy/helm/api-keys-colocated/                        @jmcnamee @NVIDIA/nvcf-control-plane-dev

# NVCA operator chart (upstream: nvca-operator-deploy).
/deploy/helm/nvca-operator/                             @NVIDIA/nvca-dev

# Self-managed stack (upstream: nvcf-self-managed-stack).
/deploy/stacks/                                         @jmcnamee

# Cassandra and OpenBao migrations.
/migrations/cassandra/                                  @mikeyrcamp @nvjmcnamee @kferris-nvidia @along-2017 @vrv3814 @bvernon-nv
/migrations/openbao/                                    @mikeyrcamp @nvjmcnamee @kferris-nvidia @along-2017 @vrv3814 @gsharma-nvidia @bvernon-nv

# Compute-plane service: nvca agent and operator (upstream: nvca).
/src/compute-plane-services/nvca/                       @NVIDIA/nvca-dev

# Compute-plane service: byoo-otel-collector (upstream: byoo-otel-collector).
/src/compute-plane-services/byoo-otel-collector/        @NVIDIA/nvca-dev @along-2017

# Compute-plane service: image-credential-helper (upstream: nvcf-image-credential-helper).
/src/compute-plane-services/image-credential-helper/    @NVIDIA/nvca-dev

# Shared Go libraries (upstream: nvcf-go).
/src/libraries/go/                                      @NVIDIA/nvca-dev

# Stargate Rust library (upstream: stargate).
/src/libraries/rust/stargate/                           @FamousDirector @barrygreengus

# All control-plane source.
/src/control-plane-services/                            @NVIDIA/nvcf-control-plane-dev

# Function autoscaler is owned by the invocation team.
/src/control-plane-services/function-autoscaler/        @NVIDIA/nvcf-invocation-dev

