{{- define "nvcf.nodeSelector" -}}
{{- if .selectors.enabled -}}
{{- $ns := dig .type (dict) .selectors -}}
{{- if or (not $ns) (not (kindIs "map" $ns)) (not (index $ns "key")) -}}
{{- $ns = dig "all" (dict) .selectors -}}
{{- end -}}
{{- if and $ns (kindIs "map" $ns) (index $ns "key") -}}
nodeSelector:
  {{ $ns.key }}: {{ $ns.value }}
{{- end -}}
{{- end -}}
{{- end -}}

{{- define "nvcf.tolerations" -}}
{{- if .tolerations.enabled -}}
{{- $tol := dig .type (list) .tolerations -}}
{{- if not (and $tol (kindIs "slice" $tol)) -}}
{{- $tol = dig "all" (list) .tolerations -}}
{{- end -}}
{{- if and $tol (kindIs "slice" $tol) -}}
tolerations:
{{ toYaml $tol }}
{{- end -}}
{{- end -}}
{{- end -}}

cassandra:
  global:
    {{- if .Values.global.imagePullSecrets }}
    imagePullSecrets:
      {{- toYaml .Values.global.imagePullSecrets | nindent 6 }}
    {{- end }}
    security:
      allowInsecureImages: true
    {{- if .Values.global.storageClass }}
    defaultStorageClass: {{ .Values.global.storageClass }}
    {{- end }}

  replicaCount: {{ dig "cassandra" "replicaCount" 3 .Values }}
  resourcesPreset: {{ dig "cassandra" "resourcesPreset" "xlarge" .Values }}

  {{- with include "nvcf.nodeSelector" (dict "type" "cassandra" "selectors" .Values.global.nodeSelectors) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- with include "nvcf.tolerations" (dict "type" "cassandra" "tolerations" .Values.global.tolerations) }}
  {{- . | nindent 2 }}
  {{- end }}
  persistence:
    size: {{ .Values.global.storageSize | default "10Gi" }}

  migrations:
    image:
      registry: {{ .Values.global.image.registry }}
      repository: {{ .Values.global.image.repository }}/nvcf-cassandra-migrations
      {{- if dig "cassandra" "migrations" "image" "tag" "" .Values }}
      tag: {{ dig "cassandra" "migrations" "image" "tag" "" .Values }}
      {{- end }}
      {{- if dig "cassandra" "migrations" "image" "pullPolicy" "" .Values }}
      pullPolicy: {{ dig "cassandra" "migrations" "image" "pullPolicy" "" .Values }}
      {{- end }}
  initialization:
    image:
      registry: {{ .Values.global.image.registry }}
      repository: {{ .Values.global.image.repository }}/alpine-k8s
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}/bitnami-cassandra
  dynamicSeedDiscovery:
    image:
      registry: {{ .Values.global.image.registry }}
      repository: {{ .Values.global.image.repository }}/bitnami-cassandra

# cert-manager subchart image overrides. The helm-nvcf-cert-manager wrapper
# passes these through to the upstream cert-manager subchart under the
# `cert-manager` key. `image.repository` is a full-path override that wins
# over the upstream `imageRegistry`/`imageNamespace`/`name` construction,
# so each component pulls from the nvcr.io mirror (regsync-configs !140)
# instead of quay.io/jetstack.
cert-manager:
  {{- if .Values.global.imagePullSecrets }}
  global:
    imagePullSecrets:
      {{- toYaml .Values.global.imagePullSecrets | nindent 6 }}
  {{- end }}
  image:
    repository: {{ .Values.global.image.registry }}/{{ .Values.global.image.repository }}/cert-manager-controller
  webhook:
    image:
      repository: {{ .Values.global.image.registry }}/{{ .Values.global.image.repository }}/cert-manager-webhook
  cainjector:
    image:
      repository: {{ .Values.global.image.registry }}/{{ .Values.global.image.repository }}/cert-manager-cainjector
  acmesolver:
    image:
      repository: {{ .Values.global.image.registry }}/{{ .Values.global.image.repository }}/cert-manager-acmesolver
  startupapicheck:
    image:
      repository: {{ .Values.global.image.registry }}/{{ .Values.global.image.repository }}/cert-manager-startupapicheck

openbao:
  {{- if .Values.global.imagePullSecrets }}
  global:
    imagePullSecrets:
      {{- toYaml .Values.global.imagePullSecrets | nindent 6 }}
  {{- end }}
  migrations:
    image:
      registry: {{ .Values.global.image.registry }}
      repository: {{ .Values.global.image.repository }}/nvcf-openbao-migrations
      {{- if dig "openbao" "migrations" "image" "tag" "" .Values }}
      tag: {{ dig "openbao" "migrations" "image" "tag" "" .Values }}
      {{- end }}

    # merge the rest of the user-supplied migrations block, but drop
    # its image sub-block so we don't clobber the defaults above
    {{- with .Values.openbao.migrations }}
    {{- range $key, $value := . }}
    {{- if ne $key "image" }}
    {{ $key }}:
      {{- toYaml $value | nindent 6 }}
    {{- end }}
    {{- end }}
    {{- end }}

  injector:
    image:
      registry: {{ .Values.global.image.registry }}
      repository: {{ .Values.global.image.repository }}/oss-vault-k8s
    agentImage:
      registry: {{ .Values.global.image.registry }}
      repository: {{ .Values.global.image.repository }}/nvcf-openbao
    {{- with include "nvcf.nodeSelector" (dict "type" "vault" "selectors" .Values.global.nodeSelectors) }}
    {{- . | nindent 4 }}
    {{- end }}
    {{- with include "nvcf.tolerations" (dict "type" "vault" "tolerations" .Values.global.tolerations) }}
    {{- . | nindent 4 }}
    {{- end }}
    replicas: {{ .Values.openbao.injector.replicas }}
    {{- with .Values.openbao.injector.webhook }}
    webhook:
      {{- toYaml . | nindent 6 }}
    {{- end }}
    podDisruptionBudget:
      minAvailable: 1
  server:
    image:
      registry: {{ .Values.global.image.registry }}
      repository: {{ .Values.global.image.repository }}/nvcf-openbao
    {{- with include "nvcf.nodeSelector" (dict "type" "vault" "selectors" .Values.global.nodeSelectors) }}
    {{- . | nindent 4 }}
    {{- end }}
    {{- with include "nvcf.tolerations" (dict "type" "vault" "tolerations" .Values.global.tolerations) }}
    {{- . | nindent 4 }}
    {{- end }}

    dataStorage:
      {{- if .Values.global.storageClass }}
      storageClass: {{ .Values.global.storageClass }}
      {{- end }}
      size: {{ .Values.global.storageSize | default "10Gi" }}

nats:
  {{- if .Values.global.imagePullSecrets }}
  global:
    image:
      pullSecretNames:
        {{- range .Values.global.imagePullSecrets }}
        - {{ .name }}
        {{- end }}
  {{- end }}
  container:
    image:
      registry: {{ .Values.global.image.registry }}
      repository: {{ .Values.global.image.repository }}/nats-server
      tag: 2.11.17-alpine3.22
  reloader:
    image:
      registry: {{ .Values.global.image.registry }}
      repository: {{ .Values.global.image.repository }}/nats-server-config-reloader
      tag: "0.23.0"
  natsBox:
    container:
      image:
        registry: {{ .Values.global.image.registry }}
        repository: {{ .Values.global.image.repository }}/nats-box
        tag: 0.19.7-nonroot
  nkeyJob:
    image:
      registry: {{ .Values.global.image.registry }}
      repository: {{ .Values.global.image.repository }}/alpine-k8s
  {{- $natsNs := include "nvcf.nodeSelector" (dict "type" "controlplane" "selectors" .Values.global.nodeSelectors) -}}
  {{- $natsTol := include "nvcf.tolerations" (dict "type" "controlplane" "tolerations" .Values.global.tolerations) -}}
  {{- if or $natsNs $natsTol }}
  podTemplate:
    merge:
      spec:
        {{- with $natsNs }}
        {{- . | nindent 8 }}
        {{- end }}
        {{- with $natsTol }}
        {{- . | nindent 8 }}
        {{- end }}
  {{- end }}

  {{- if .Values.global.storageClass }}
  config:
    jetstream:
      fileStore:
        pvc:
          storageClassName: {{ .Values.global.storageClass }}
  {{- end }}

apikeys:
  fullnameOverride: api-keys
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}/nvcf-api-keys-service
  {{- with include "nvcf.nodeSelector" (dict "type" "controlplane" "selectors" .Values.global.nodeSelectors) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- with include "nvcf.tolerations" (dict "type" "controlplane" "tolerations" .Values.global.tolerations) }}
  {{- . | nindent 2 }}
  {{- end }}

natsAuthCalloutService:
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}/nvcf-nats-auth-callout-service

{{- $workerEndpoints := dig "global" "workerEndpoints" dict .Values }}
{{- $nvcfWorkerServiceURL := dig "nvcfServiceURL" "" $workerEndpoints }}
{{- $nvcfWorkerGrpcServiceURL := dig "nvcfGrpcServiceURL" "" $workerEndpoints }}
{{- $grpcProxyNVCFGrpcServiceURL := dig "grpcproxy" "nvcfGrpcServiceURL" "" .Values | default $nvcfWorkerGrpcServiceURL }}
{{- $nvcfNatsWorkerServiceURL := dig "nvcfNatsServiceURL" "" $workerEndpoints }}
{{- $essWorkerBaseURL := dig "essServiceURL" "" $workerEndpoints }}
{{- $nvctWorkerServiceURL := dig "nvctServiceURL" "" $workerEndpoints }}
{{- $nvctWorkerGrpcServiceURL := dig "nvctGrpcServiceURL" "" $workerEndpoints }}
{{- $invocationWorkerBaseURL := dig "invocationServiceURL" "" $workerEndpoints }}
{{- $grpcProxyWorkerConnectURL := dig "grpcProxyWorkerConnectURL" "" $workerEndpoints }}
{{- $grpcProxyWorkerConnectBaseURL := dig "grpcproxy" "workerConnectBaseURL" "" .Values | default $grpcProxyWorkerConnectURL }}
{{- $nvcfApiGrpcRouteHostnames := dig "ingress" "gatewayApi" "routes" "nvcfApi" "grpc" "hostnames" (list) .Values | default (list (printf "api-grpc.%s" .Values.global.domain)) }}
{{- $nvctApiGrpcRouteHostnames := dig "ingress" "gatewayApi" "routes" "nvctApi" "grpc" "hostnames" (list) .Values | default (list (printf "tasks-grpc.%s" .Values.global.domain)) }}
api:
  fullnameOverride: nvcf-api
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    {{- $apiImageName := dig "api" "image" "name" "nvcf-service-oss" .Values }}
    {{- $apiImageRepository := printf "%s/%s" .Values.global.image.repository $apiImageName }}
    repository: {{ dig "api" "image" "repository" $apiImageRepository .Values }}
    {{- with dig "api" "image" "tag" nil .Values }}
    tag: {{ . | quote }}
    {{- end }}
  {{- with include "nvcf.nodeSelector" (dict "type" "controlplane" "selectors" .Values.global.nodeSelectors) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- with include "nvcf.tolerations" (dict "type" "controlplane" "tolerations" .Values.global.tolerations) }}
  {{- . | nindent 2 }}
  {{- end }}
  accountBootstrap:
    image:
      registry: {{ .Values.global.image.registry }}
      repository: {{ .Values.global.image.repository }}/alpine-k8s
      tag: 1.36.1
      pullPolicy: IfNotPresent

    registryCredentials: []

    limits:
      {{- $maxFunctions := .Values.accounts.limits.maxFunctions | default 50 }}
      {{- if or (lt $maxFunctions 1) (gt $maxFunctions 50) }}
      {{- fail "accounts.limits.maxFunctions must be greater than 0 and less than or equal to 50" }}
      {{- end }}
      maxFunctions: {{ $maxFunctions }}

      {{- $maxTasks := .Values.accounts.limits.maxTasks | default 50 }}
      {{- if or (lt $maxTasks 1) (gt $maxTasks 50) }}
      {{- fail "accounts.limits.maxTasks must be greater than 0 and less than or equal to 50" }}
      {{- end }}
      maxTasks: {{ $maxTasks }}

      {{- $maxTelemetries := .Values.accounts.limits.maxTelemetries | default 25 }}
      {{- if or (lt $maxTelemetries 1) (gt $maxTelemetries 25) }}
      {{- fail "accounts.limits.maxTelemetries must be greater than 0 and less than or equal to 25" }}
      {{- end }}
      maxTelemetries: {{ $maxTelemetries }}

      {{- $maxRegistryCreds := .Values.accounts.limits.maxRegistryCreds | default 10 }}
      {{- if or (lt $maxRegistryCreds 1) (gt $maxRegistryCreds 25) }}
      {{- fail "accounts.limits.maxRegistryCreds must be greater than 0 and less than or equal to 25" }}
      {{- end }}
      maxRegistryCreds: {{ $maxRegistryCreds }}

  env:
    NVCF_NATS_REGION_PLACEMENT_TAG: "dc"
    NVCF_SIDECARS_HOSTNAME: {{ .Values.global.image.registry }}
    NVCF_SIDECARS_REPOSITORY: {{ .Values.global.image.repository }}
    {{- with $nvcfWorkerServiceURL }}
    NVCF_FQDN: {{ . | quote }}
    {{- end }}
    {{- with $nvcfWorkerGrpcServiceURL }}
    NVCF_GLOBAL_FQDN_GRPC: {{ . | quote }}
    {{- end }}
    {{- with $nvcfNatsWorkerServiceURL }}
    NVCF_NATS_WORKER_URL: {{ . | quote }}
    {{- end }}
    {{- with $essWorkerBaseURL }}
    # Keep the legacy worker alias until all API builds consume nvcf.ess.base-url directly.
    NVCF_ESS_WORKER_BASE_URL: {{ . | quote }}
    NVCF_ESS_BASE_URL: {{ . | quote }}
    {{- end }}
    NVCF_REGISTRIES_NGC_CONTAINER_REGISTRY_URL: "https://nvcr.io"
    NVCF_REGISTRIES_NGC_BASE_URL: "https://api.ngc.nvidia.com"
    NVCF_REGISTRIES_NGC_OAUTH2_BASE_URL: "https://authn.nvidia.com"
    NVCF_REGISTRIES_NGC_OAUTH2_GROUP_SCOPE: "ngc"
    NVCF_REGISTRIES_RECOGNIZED_CONTAINER_NGC_HOSTNAME: "nvcr.io"
    NVCF_REGISTRIES_RECOGNIZED_HELM_NGC_HOSTNAME: "helm.ngc.nvidia.com"
    NVCF_REGISTRIES_RECOGNIZED_HELM_NGC_OAUTH2_BASE_URL: "https://authn.nvidia.com"
    NVCF_REGISTRIES_RECOGNIZED_HELM_NGC_OAUTH2_GROUP_SCOPE: "ngc"
    NVCF_REGISTRIES_RECOGNIZED_MODEL_NGC_HOSTNAME: "api.ngc.nvidia.com"
    NVCF_REGISTRIES_RECOGNIZED_MODEL_NGC_OAUTH2_BASE_URL: "https://authn.nvidia.com"
    NVCF_REGISTRIES_RECOGNIZED_MODEL_NGC_OAUTH2_GROUP_SCOPE: "ngc"
    NVCF_REGISTRIES_RECOGNIZED_RESOURCE_NGC_HOSTNAME: "api.ngc.nvidia.com"
    NVCF_REGISTRIES_RECOGNIZED_RESOURCE_NGC_OAUTH2_BASE_URL: "https://authn.nvidia.com"
    NVCF_REGISTRIES_RECOGNIZED_RESOURCE_NGC_OAUTH2_GROUP_SCOPE: "ngc"
    # Observability
    MANAGEMENT_TRACING_ENABLED: {{ .Values.global.observability.tracing.enabled | quote }}
    {{- if .Values.global.observability.tracing.enabled }}
    MANAGEMENT_OTLP_TRACING_ENDPOINT: "{{ .Values.global.observability.tracing.collectorProtocol }}://{{ .Values.global.observability.tracing.collectorEndpoint }}:{{ .Values.global.observability.tracing.collectorPort }}/v1/traces"
    {{- end }}

invocation:
  fullnameOverride: invocation-service
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}/nvcf-invocation-service
  {{- with include "nvcf.nodeSelector" (dict "type" "controlplane" "selectors" .Values.global.nodeSelectors) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- with include "nvcf.tolerations" (dict "type" "controlplane" "tolerations" .Values.global.tolerations) }}
  {{- . | nindent 2 }}
  {{- end }}

  env:
    # Observability
    {{- if .Values.global.observability.tracing.enabled }}
    SERVER__TRACING__ENDPOINT_IP: "{{ .Values.global.observability.tracing.collectorProtocol }}://{{ .Values.global.observability.tracing.collectorEndpoint }}"
    SERVER__TRACING__ENDPOINT_PORT: {{ .Values.global.observability.tracing.collectorPort }}
    {{- else }}
    SERVER__ENVFILTER_DIRECTIVE: "otel::tracing=off,otel=off,server=trace,info"
    {{- end }}
    {{- if .Values.rateLimiter.enabled }}
    RATE_LIMIT_ENABLED: "true"
    RATE_LIMIT_ADDRESS: "http://ratelimiter.nvcf.svc.cluster.local:7777"
    {{- end }}
    {{- with $invocationWorkerBaseURL }}
    WORKER_STREAM_PROPERTIES__SELF_ADDRESS: {{ . | quote }}
    {{- end }}
  
nvctApi:
  fullnameOverride: nvct-api
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}/nvct-service-oss

  env:
    NVCT_SIDECARS_HOSTNAME: {{ .Values.global.image.registry }}
    NVCT_SIDECARS_REPOSITORY: {{ .Values.global.image.repository }}
    {{- with $nvctWorkerServiceURL }}
    NVCT_FQDN: {{ . | quote }}
    {{- end }}
    {{- with $nvctWorkerGrpcServiceURL }}
    NVCT_GLOBAL_FQDN_GRPC: {{ . | quote }}
    {{- end }}
    {{- with $essWorkerBaseURL }}
    NVCT_ESS_BASE_URL: {{ . | quote }}
    NVCT_ESS_WORKER_BASE_URL: {{ . | quote }}
    {{- end }}
    # Observability
    MANAGEMENT_TRACING_ENABLED: {{ .Values.global.observability.tracing.enabled }}
    {{- if .Values.global.observability.tracing.enabled }}
    MANAGEMENT_OTLP_TRACING_ENDPOINT: "{{ .Values.global.observability.tracing.collectorProtocol }}://{{ .Values.global.observability.tracing.collectorEndpoint }}:{{ .Values.global.observability.tracing.collectorPort }}/v1/traces"
    {{- end }}

grpcproxy:
  fullnameOverride: grpc-proxy
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}/nvcf-grpc-proxy
  {{- with include "nvcf.nodeSelector" (dict "type" "controlplane" "selectors" .Values.global.nodeSelectors) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- with include "nvcf.tolerations" (dict "type" "controlplane" "tolerations" .Values.global.tolerations) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- with $grpcProxyWorkerConnectBaseURL }}
  workerConnectBaseURL: {{ . | quote }}
  {{- end }}

  env:
    # Observability
    {{- if .Values.global.observability.tracing.enabled }}
    OTEL_EXPORTER_OTLP_ENDPOINT: "{{ .Values.global.observability.tracing.collectorProtocol }}://{{ .Values.global.observability.tracing.collectorEndpoint }}:{{ .Values.global.observability.tracing.collectorPort }}"
    {{- else }}
    TRACING: "none" # this is ineffective, but the env list must be non-empty
    {{- end }}
    {{- with $grpcProxyNVCFGrpcServiceURL }}
    NVCF_FQDN_GRPC: {{ . | quote }}
    {{- end }}
    {{- with $nvcfNatsWorkerServiceURL }}
    NATS_FQDN: {{ . | quote }}
    {{- end }}
    {{- if .Values.rateLimiter.enabled }}
    RATE_LIMIT_ENABLED: "true"
    RATE_LIMIT_ADDR: "http://ratelimiter.nvcf.svc.cluster.local:7777"
    {{- end }}

rateLimiter:
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}
  {{- if .Values.global.nodeSelectors.enabled }}
  nodeSelector:
    {{ .Values.global.nodeSelectors.controlplane.key }}: {{ .Values.global.nodeSelectors.controlplane.value }}
  {{- end }}
  replicaCount: {{ .Values.rateLimiter.replicaCount }}
  {{- if .Values.global.observability.tracing.enabled }}
  env:
    OTEL_EXPORTER_OTLP_ENDPOINT: "{{ .Values.global.observability.tracing.collectorProtocol }}://{{ .Values.global.observability.tracing.collectorEndpoint }}:{{ .Values.global.observability.tracing.collectorPort }}"
  {{- end }}

ess:
  fullnameOverride: ess-api
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}/ess-api
  {{- with include "nvcf.nodeSelector" (dict "type" "controlplane" "selectors" .Values.global.nodeSelectors) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- with include "nvcf.tolerations" (dict "type" "controlplane" "tolerations" .Values.global.tolerations) }}
  {{- . | nindent 2 }}
  {{- end }}

  env:
    # Observability
    MANAGEMENT_TRACING_ENABLED: {{ .Values.global.observability.tracing.enabled | quote }}
    {{- if .Values.global.observability.tracing.enabled }}
    MANAGEMENT_OTLP_TRACING_ENDPOINT: "{{ .Values.global.observability.tracing.collectorProtocol }}://{{ .Values.global.observability.tracing.collectorEndpoint }}:{{ .Values.global.observability.tracing.collectorPort }}/v1/traces"
    {{- end }}

notary:
  fullnameOverride: notary-service
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}/notary-service
  {{- with include "nvcf.nodeSelector" (dict "type" "controlplane" "selectors" .Values.global.nodeSelectors) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- with include "nvcf.tolerations" (dict "type" "controlplane" "tolerations" .Values.global.tolerations) }}
  {{- . | nindent 2 }}
  {{- end }}

  env:
    # Observability
    MANAGEMENT_TRACING_ENABLED: {{ .Values.global.observability.tracing.enabled | quote }}
    {{- if .Values.global.observability.tracing.enabled }}
    MANAGEMENT_OTLP_TRACING_ENDPOINT: "{{ .Values.global.observability.tracing.collectorProtocol }}://{{ .Values.global.observability.tracing.collectorEndpoint }}:{{ .Values.global.observability.tracing.collectorPort }}/v1/traces"
    {{- end }}

sis:
  fullnameOverride: spot-instance-service
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}/spot
    {{- if dig "sis" "image" "tag" "" .Values }}
    tag: {{ dig "sis" "image" "tag" "" .Values }}
    {{- end }}
  {{- with include "nvcf.nodeSelector" (dict "type" "controlplane" "selectors" .Values.global.nodeSelectors) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- with include "nvcf.tolerations" (dict "type" "controlplane" "tolerations" .Values.global.tolerations) }}
  {{- . | nindent 2 }}
  {{- end }}

  # LLS/TURN HMAC rotation configuration
  lls:
    enabled: {{ dig "addons" "lls" "enabled" false .Values }}
    hmacRotation:
      image:
        registry: {{ .Values.global.image.registry }}
        repository: {{ .Values.global.image.repository }}/nvcf-openbao-migrations
        {{- if dig "addons" "lls" "hmacRotation" "image" "tag" "" .Values }}
        tag: {{ dig "addons" "lls" "hmacRotation" "image" "tag" "" .Values }}
        {{- end }}

  env:
    # Observability
    MANAGEMENT_TRACING_ENABLED: {{ .Values.global.observability.tracing.enabled | quote }}
    MANAGEMENT_PROMETHEUS_METRICS_EXPORT_ENABLED: {{ .Values.global.observability.metrics.enabled | quote }}
    MANAGEMENT_METRICS_ENABLE_ALL: {{ .Values.global.observability.metrics.enabled | quote }}
    {{- if .Values.global.observability.tracing.enabled }}
    MANAGEMENT_OTLP_TRACING_ENDPOINT: "{{ .Values.global.observability.tracing.collectorProtocol }}://{{ .Values.global.observability.tracing.collectorEndpoint }}:{{ .Values.global.observability.tracing.collectorPort }}/v1/traces"
    {{- end }}

adminIssuerProxy:
  fullnameOverride: admin-token-issuer-proxy
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}/admin-token-issuer-proxy
  {{- with include "nvcf.nodeSelector" (dict "type" "controlplane" "selectors" .Values.global.nodeSelectors) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- with include "nvcf.tolerations" (dict "type" "controlplane" "tolerations" .Values.global.tolerations) }}
  {{- . | nindent 2 }}
  {{- end }}
  gateway:
    enabled: true
    namespace: {{ .Values.ingress.gatewayApi.gateways.shared.namespace }}
    gatewayRef:
      name: {{ required "ingress.gatewayApi.gateways.shared.name is required" .Values.ingress.gatewayApi.gateways.shared.name }}
    hostname: "api-keys.{{ .Values.global.domain }}"
    path: "/v1/admin/keys"

stateMetrics:
  enabled: false
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}/nvcf-state-metrics-service
  {{- with include "nvcf.nodeSelector" (dict "type" "controlplane" "selectors" .Values.global.nodeSelectors) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- with include "nvcf.tolerations" (dict "type" "controlplane" "tolerations" .Values.global.tolerations) }}
  {{- . | nindent 2 }}
  {{- end }}
  # Disable ServiceMonitor for environments without Prometheus Operator
  serviceMonitor:
    enabled: false

reval:
  fullnameOverride: reval
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}/reval-server
  securityContext:
    runAsNonRoot: true
    runAsUser: 65532
  {{- with include "nvcf.nodeSelector" (dict "type" "controlplane" "selectors" .Values.global.nodeSelectors) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- with include "nvcf.tolerations" (dict "type" "controlplane" "tolerations" .Values.global.tolerations) }}
  {{- . | nindent 2 }}
  {{- end }}

llmApiGateway:
  enabled: {{ dig "addons" "llm" "enabled" false .Values }}
  fullnameOverride: llm-api-gateway
  replicaCount: {{ dig "addons" "llm" "gateway" "replicaCount" 3 .Values }}
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ dig "addons" "llm" "gateway" "image" "registry" .Values.global.image.registry .Values }}
    repository: {{ dig "addons" "llm" "gateway" "image" "repository" (printf "%s/llm-api-gateway" .Values.global.image.repository) .Values }}
    {{- with dig "addons" "llm" "gateway" "image" "tag" "" .Values }}
    tag: {{ . | quote }}
    {{- end }}
    {{- with dig "addons" "llm" "gateway" "image" "pullPolicy" "" .Values }}
    pullPolicy: {{ . | quote }}
    {{- end }}
  {{- with include "nvcf.nodeSelector" (dict "type" "controlplane" "selectors" .Values.global.nodeSelectors) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- with include "nvcf.tolerations" (dict "type" "controlplane" "tolerations" .Values.global.tolerations) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- if dig "addons" "llm" "gateway" "auth" "grpcInsecure" false .Values }}
  config:
    nvcfGrpcInsecure: true
  {{- end }}
  metrics:
    enabled: {{ dig "addons" "llm" "gateway" "metrics" "enabled" true .Values }}
    serviceMonitor:
      enabled: {{ dig "addons" "llm" "gateway" "metrics" "serviceMonitor" "enabled" (dig "addons" "llm" "gateway" "metrics" "enabled" true .Values) .Values }}
  observability:
    tracing:
      enabled: {{ .Values.global.observability.tracing.enabled }}
      {{- if .Values.global.observability.tracing.enabled }}
      endpoint: "{{ .Values.global.observability.tracing.collectorProtocol }}://{{ .Values.global.observability.tracing.collectorEndpoint }}:{{ .Values.global.observability.tracing.collectorPort }}"
      {{- end }}

llmRequestRouter:
  enabled: {{ dig "addons" "llm" "enabled" false .Values }}
  fullnameOverride: llm-request-router
  replicaCount: {{ dig "addons" "llm" "requestRouter" "replicaCount" 3 .Values }}
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}/stargate
  {{- with include "nvcf.nodeSelector" (dict "type" "controlplane" "selectors" .Values.global.nodeSelectors) }}
  {{- . | nindent 2 }}
  {{- end }}
  {{- with include "nvcf.tolerations" (dict "type" "controlplane" "tolerations" .Values.global.tolerations) }}
  {{- . | nindent 2 }}
  {{- end }}
  metrics:
    enabled: {{ dig "addons" "llm" "requestRouter" "metrics" "enabled" true .Values }}
    serviceMonitor:
      enabled: {{ dig "addons" "llm" "requestRouter" "metrics" "serviceMonitor" "enabled" (dig "addons" "llm" "requestRouter" "metrics" "enabled" true .Values) .Values }}
  observability:
    tracing:
      enabled: {{ .Values.global.observability.tracing.enabled }}
      {{- if .Values.global.observability.tracing.enabled }}
      endpoint: "{{ .Values.global.observability.tracing.collectorProtocol }}://{{ .Values.global.observability.tracing.collectorEndpoint }}:{{ .Values.global.observability.tracing.collectorPort }}"
      {{- end }}
  {{- with dig "addons" "llm" "requestRouter" "loadBalancer" dict .Values }}
  loadBalancer:
    {{- toYaml . | nindent 4 }}
  {{- end }}
  {{- /* Compound guard: skip the entire PKI block (and its required/fail
       validations) when the LLM addon itself is disabled. helmfile's
       `condition: addons.llm.enabled` already suppresses the chart release,
       so an operator staging pki.enabled=true ahead of llm.enabled=true
       should not be punished with confusing required errors during render. */ -}}
  {{- if and (dig "addons" "llm" "enabled" false .Values) (dig "addons" "llm" "pki" "enabled" false .Values) }}
  {{- $secretName := dig "addons" "llm" "pki" "secretName" "stargate-quic-tls" .Values }}
  {{- $allowedDomains := required "addons.llm.pki.allowedDomains is required when addons.llm.pki.enabled is true" (dig "addons" "llm" "pki" "allowedDomains" "" .Values) }}
  {{- $dnsNames := dig "addons" "llm" "pki" "dnsNames" (list) .Values }}
  {{- if eq (len $dnsNames) 0 }}
  {{- fail "addons.llm.pki.dnsNames must contain at least one DNS name when addons.llm.pki.enabled is true" }}
  {{- end }}
  {{- /* Provisioning hook reuses the same image the k8s-openbao chart drives;
       fall back to openbao.migrations.image.tag so operators set the version
       in one place. */ -}}
  {{- $pkiImageTag := dig "addons" "llm" "pki" "image" "tag" (dig "openbao" "migrations" "image" "tag" "" .Values) .Values }}
  {{- if not $pkiImageTag }}
  {{- fail "addons.llm.pki.image.tag (or openbao.migrations.image.tag) is required when addons.llm.pki.enabled is true" }}
  {{- end }}
  certificate:
    enabled: true
    secretName: {{ $secretName | quote }}
    issuerRef:
      kind: {{ dig "addons" "llm" "pki" "issuerKind" "ClusterIssuer" .Values | quote }}
      name: {{ dig "addons" "llm" "pki" "issuerName" "nvcf-openbao-pki" .Values | quote }}
    dnsNames:
      {{- toYaml $dnsNames | nindent 6 }}
  tls:
    secretName: {{ $secretName | quote }}
    mountPath: {{ dig "addons" "llm" "pki" "mountPath" "/etc/stargate/tls" .Values | quote }}
    certPath: {{ dig "addons" "llm" "pki" "certPath" "/etc/stargate/tls/tls.crt" .Values | quote }}
    keyPath: {{ dig "addons" "llm" "pki" "keyPath" "/etc/stargate/tls/tls.key" .Values | quote }}
    quicInsecure: false
  pki:
    enabled: true
    namespace: {{ dig "addons" "llm" "pki" "namespace" "vault-system" .Values | quote }}
    allowedDomains: {{ $allowedDomains | quote }}
    image:
      registry: {{ dig "addons" "llm" "pki" "image" "registry" .Values.global.image.registry .Values | quote }}
      repository: {{ dig "addons" "llm" "pki" "image" "repository" (printf "%s/nvcf-openbao-migrations" .Values.global.image.repository) .Values | quote }}
      tag: {{ $pkiImageTag | quote }}
      pullPolicy: {{ dig "addons" "llm" "pki" "image" "pullPolicy" "IfNotPresent" .Values | quote }}
    {{- if .Values.global.imagePullSecrets }}
    imagePullSecrets:
      {{- toYaml .Values.global.imagePullSecrets | nindent 6 }}
    {{- end }}
  {{- end }}

vanityGateway:
  fullnameOverride: vanity-gateway
  replicaCount: {{ dig "addons" "vanityGateway" "replicaCount" 2 .Values }}
  {{- if .Values.global.imagePullSecrets }}
  imagePullSecrets:
    {{- toYaml .Values.global.imagePullSecrets | nindent 4 }}
  {{- end }}
  image:
    registry: {{ .Values.global.image.registry }}
    repository: {{ .Values.global.image.repository }}/nvcf-ai-api-gateway-service
    {{- if dig "addons" "vanityGateway" "image" "tag" "" .Values }}
    tag: {{ dig "addons" "vanityGateway" "image" "tag" "" .Values | quote }}
    {{- end }}
    pullPolicy: {{ dig "addons" "vanityGateway" "image" "pullPolicy" "IfNotPresent" .Values }}
  config:
    mappingPath: {{ dig "addons" "vanityGateway" "config" "mappingPath" "/etc/vanity-gateway/config/config.yaml" .Values | quote }}
    nvcfApiEndpoint: {{ dig "addons" "vanityGateway" "config" "nvcfApiEndpoint" "http://invocation.nvcf.svc.cluster.local:8080" .Values | quote }}
    {{- if .Values.global.observability.tracing.enabled }}
    otelExporterOtlpEndpoint: "{{ .Values.global.observability.tracing.collectorProtocol }}://{{ .Values.global.observability.tracing.collectorEndpoint }}:{{ .Values.global.observability.tracing.collectorPort }}"
    {{- else }}
    otelExporterOtlpEndpoint: ""
    {{- end }}
    secretsPath: {{ dig "addons" "vanityGateway" "config" "secretsPath" "" .Values | quote }}
    privateModelNameRegexPattern: {{ dig "addons" "vanityGateway" "config" "privateModelNameRegexPattern" "" .Values | quote }}
    awsRegion: {{ dig "addons" "vanityGateway" "config" "awsRegion" "" .Values | quote }}
    shadowMaxConcurrent: {{ dig "addons" "vanityGateway" "config" "shadowMaxConcurrent" 256 .Values }}
  mappingConfig:
    {{ dig "addons" "vanityGateway" "mappingConfig" (dict "v2config" (dict "openai" (dict) "vanity" (dict))) .Values | toYaml | nindent 4 | trim }}
  serviceMonitor:
    enabled: {{ dig "addons" "vanityGateway" "serviceMonitor" "enabled" false .Values }}
    interval: {{ dig "addons" "vanityGateway" "serviceMonitor" "interval" "60s" .Values | quote }}
    labels:
      {{ dig "addons" "vanityGateway" "serviceMonitor" "labels" dict .Values | toYaml | nindent 6 | trim }}
  {{- with (dig "addons" "vanityGateway" "service" dict .Values) }}
  service:
    {{ . | toYaml | nindent 4 | trim }}
  {{- end }}
  {{- with (dig "addons" "vanityGateway" "serviceAccount" dict .Values) }}
  serviceAccount:
    {{ . | toYaml | nindent 4 | trim }}
  {{- end }}
  {{- with (dig "addons" "vanityGateway" "podAnnotations" dict .Values) }}
  podAnnotations:
    {{ . | toYaml | nindent 4 | trim }}
  {{- end }}
  {{- with (dig "addons" "vanityGateway" "podLabels" dict .Values) }}
  podLabels:
    {{ . | toYaml | nindent 4 | trim }}
  {{- end }}
  {{- with (dig "addons" "vanityGateway" "podSecurityContext" dict .Values) }}
  podSecurityContext:
    {{ . | toYaml | nindent 4 | trim }}
  {{- end }}
  {{- with (dig "addons" "vanityGateway" "securityContext" dict .Values) }}
  securityContext:
    {{ . | toYaml | nindent 4 | trim }}
  {{- end }}
  {{- with (dig "addons" "vanityGateway" "resources" dict .Values) }}
  resources:
    {{ . | toYaml | nindent 4 | trim }}
  {{- end }}
  {{- if .Values.global.nodeSelectors.enabled }}
  nodeSelector:
    {{ .Values.global.nodeSelectors.controlplane.key }}: {{ .Values.global.nodeSelectors.controlplane.value }}
  {{- else }}
  {{- with (dig "addons" "vanityGateway" "nodeSelector" dict .Values) }}
  nodeSelector:
    {{ . | toYaml | nindent 4 | trim }}
  {{- end }}
  {{- end }}
  {{- with (dig "addons" "vanityGateway" "tolerations" (list) .Values) }}
  tolerations:
    {{ . | toYaml | nindent 4 | trim }}
  {{- end }}
  {{- with (dig "addons" "vanityGateway" "affinity" dict .Values) }}
  affinity:
    {{ . | toYaml | nindent 4 | trim }}
  {{- end }}

nvcfGatewayRoutes:
  {{- $natsRouteEnabled := dig "ingress" "gatewayApi" "routes" "nats" "enabled" false .Values }}
  {{- $essRouteEnabled := dig "ingress" "gatewayApi" "routes" "ess" "enabled" false .Values }}
  domain: "{{ .Values.global.domain }}"
  gateways:
    shared:
      name: {{ required "ingress.gatewayApi.gateways.shared.name is required" .Values.ingress.gatewayApi.gateways.shared.name }}
      namespace: {{ required "ingress.gatewayApi.gateways.shared.namespace is required" .Values.ingress.gatewayApi.gateways.shared.namespace }}
    grpc:
      name: {{ required "ingress.gatewayApi.gateways.grpc.name is required" .Values.ingress.gatewayApi.gateways.grpc.name }}
      namespace: {{ required "ingress.gatewayApi.gateways.grpc.namespace is required" .Values.ingress.gatewayApi.gateways.grpc.namespace }}
    {{- if $natsRouteEnabled }}
    nats:
      name: {{ required "ingress.gatewayApi.gateways.nats.name is required when ingress.gatewayApi.routes.nats.enabled is true" .Values.ingress.gatewayApi.gateways.nats.name }}
      namespace: {{ required "ingress.gatewayApi.gateways.nats.namespace is required when ingress.gatewayApi.routes.nats.enabled is true" .Values.ingress.gatewayApi.gateways.nats.namespace }}
      listenerName: {{ dig "ingress" "gatewayApi" "gateways" "nats" "listenerName" "nats" .Values }}
    {{- end }}
  routes:
    nvcfApi:
      routeAnnotations:
        {{ dig "ingress" "gatewayApi" "routes" "nvcfApi" "routeAnnotations" dict .Values | toYaml | nindent 8 | trim }}
      grpc:
        enabled: {{ dig "ingress" "gatewayApi" "routes" "nvcfApi" "grpc" "enabled" false .Values }}
        {{- with $nvcfApiGrpcRouteHostnames }}
        hostnames:
          {{- toYaml . | nindent 10 }}
        {{- end }}
    nvctApi:
      routeAnnotations:
        {{ dig "ingress" "gatewayApi" "routes" "nvctApi" "routeAnnotations" dict .Values | toYaml | nindent 8 | trim }}
      grpc:
        enabled: {{ dig "ingress" "gatewayApi" "routes" "nvctApi" "grpc" "enabled" false .Values }}
        {{- with $nvctApiGrpcRouteHostnames }}
        hostnames:
          {{- toYaml . | nindent 10 }}
        {{- end }}
    apiKeys:
      routeAnnotations:
        {{ dig "ingress" "gatewayApi" "routes" "apiKeys" "routeAnnotations" dict .Values | toYaml | nindent 8 | trim }}
    invocation:
      routeAnnotations:
        {{ dig "ingress" "gatewayApi" "routes" "invocation" "routeAnnotations" dict .Values | toYaml | nindent 8 | trim }}
    llmInvocation:
      enabled: {{ dig "addons" "llm" "enabled" false .Values }}
      backend:
        name: llm-api-gateway
        namespace: nvcf
        port: 8080
      routeAnnotations:
        {{ dig "ingress" "gatewayApi" "routes" "llmInvocation" "routeAnnotations" dict .Values | toYaml | nindent 8 | trim }}
    vanityGateway:
      enabled: {{ dig "addons" "vanityGateway" "enabled" false .Values }}
      hostnames:
        {{ dig "ingress" "gatewayApi" "routes" "vanityGateway" "hostnames" (list) .Values | default (list (printf "vanity.%s" .Values.global.domain)) | toYaml | nindent 8 | trim }}
      backend:
        name: {{ dig "ingress" "gatewayApi" "routes" "vanityGateway" "backend" "name" "vanity-gateway" .Values }}
        namespace: {{ dig "ingress" "gatewayApi" "routes" "vanityGateway" "backend" "namespace" "nvcf" .Values }}
        port: {{ dig "ingress" "gatewayApi" "routes" "vanityGateway" "backend" "port" 8080 .Values }}
      routeAnnotations:
        {{ dig "ingress" "gatewayApi" "routes" "vanityGateway" "routeAnnotations" dict .Values | toYaml | nindent 8 | trim }}
    grpc:
      routeAnnotations:
        {{ dig "ingress" "gatewayApi" "routes" "grpc" "routeAnnotations" dict .Values | toYaml | nindent 8 | trim }}
    grpcWorker:
      enabled: {{ dig "ingress" "gatewayApi" "routes" "grpcWorker" "enabled" false .Values }}
      listenerName: {{ dig "ingress" "gatewayApi" "routes" "grpcWorker" "listenerName" "worker-tcp" .Values }}
      routeAnnotations:
        {{ dig "ingress" "gatewayApi" "routes" "grpcWorker" "routeAnnotations" dict .Values | toYaml | nindent 8 | trim }}
    nats:
      enabled: {{ $natsRouteEnabled }}
      routeAnnotations:
        {{ dig "ingress" "gatewayApi" "routes" "nats" "routeAnnotations" dict .Values | toYaml | nindent 8 | trim }}
    # ESS route attaches to the shared Gateway (backend/hostname come from chart
    # defaults); only the enable flag and annotations are environment-driven.
    ess:
      enabled: {{ $essRouteEnabled }}
      routeAnnotations:
        {{ dig "ingress" "gatewayApi" "routes" "ess" "routeAnnotations" dict .Values | toYaml | nindent 8 | trim }}
  podMonitors:
    enabled: {{ .Values.global.observability.metrics.enabled }}
