environments:
  default:
    values:
      - ../environments/base.yaml
      - ../environments/{{ requiredEnv "HELMFILE_ENV" }}.yaml

---

repositories:
  - name: nvcf
    url: {{ .Values.global.helm.sources.registry }}/{{ .Values.global.helm.sources.repository }}
    oci: true

helmDefaults:
  createNamespace: true
  devel: true
  timeout: 900
  wait: true
  waitForJobs: true
  diffArgs:
    - "--dry-run=server"

templates:
  service: &service
    chart: nvcf/helm-nvcf-{{`{{ .Release.Name }}`}}
    values:
      - ../global.yaml.gotmpl
      - ../secrets/{{ requiredEnv "HELMFILE_ENV" }}-secrets.yaml
    labels:
      release-group: services

releases:

  # --- NVCF Services ---
  - name: api-keys
    version: 1.4.0
    namespace: api-keys
    inherit:
      - template: service

  - name: sis
    version: 1.13.6
    namespace: sis
    inherit:
      - template: service

  - name: api
    version: 1.18.1
    namespace: nvcf
    inherit:
      - template: service
    needs:
      # not needed to start, but needed for bootstrapping account which is done with a script in the api helm chart
      - ess/ess-api
                      
  - name: nvct-api
    chart: nvcf/helm-nvct-api
    version: 1.0.2
    namespace: nvcf
    values:
      - ../global.yaml.gotmpl
    inherit:
      - template: service

  - name: invocation-service
    version: 1.5.2
    namespace: nvcf
    inherit:
      - template: service
    needs:
      - nvcf/api

  - name: grpc-proxy
    version: 1.6.2
    namespace: nvcf
    inherit:
      - template: service
    needs:
      - nvcf/api

  - name: ess-api
    version: 1.5.2
    namespace: ess
    inherit:
      - template: service

  - name: notary-service
    version: 1.3.1
    namespace: nvcf
    inherit:
      - template: service

  - name: admin-issuer-proxy
    chart: nvcf/helm-admin-token-issuer-proxy
    version: 1.3.1
    namespace: api-keys
    values:
      - ../global.yaml.gotmpl
    # Finding #22 (E2E 2026-04-20): admin-issuer-proxy was not installed by
    # the first make install. helmfile list showed INSTALLED=true but
    # helm list -A confirmed no release existed.
    #
    # Root cause: helmfile 1.1.9 processes releases layer-by-layer rather
    # than strictly DAG-aware. With needs: api-keys/api-keys, this release
    # was in DAG layer 2, waiting for ALL layer-1 peers to finish, not just
    # api-keys. On a clean k3d cluster the sis release in layer 1 can spend
    # up to 15 minutes stuck on multi-node sideload races before helmfile
    # aborts the sync; when sis fails (or the run is interrupted), layer 2
    # releases are silently skipped even though their specific dependency
    # (api-keys) completed successfully.
    #
    # Fix: drop the needs on api-keys/api-keys. The proxy does not require
    # api-keys to be running at install time. The api-keys namespace is
    # auto-created by helmDefaults.createNamespace=true, and api-keys is
    # only a runtime callee (serviceMetadataURL); runtime readiness is
    # handled by the pod readinessProbe, not install ordering. With no
    # needs, admin-issuer-proxy installs in DAG layer 1 in parallel with
    # api-keys/sis/ess-api and is immune to sibling flakes.
    #
    # Also add a release-group label so the release is consistent with its
    # peers (all other services in this file carry release-group: services).
    labels:
      release-group: services

  - name: reval
    chart: nvcf/helm-reval
    version: 1.3.1
    namespace: nvcf
    values:
      - ../global.yaml.gotmpl
    labels:
      release-group: services

  - name: nats-auth-callout-service
    chart: nvcf/helm-nvcf-nats-auth-callout-service
    version: 1.0.1
    namespace: nats-system
    values:
      - ../global.yaml.gotmpl
      {{- if .Values.global.imagePullSecrets }}
      - imagePullSecrets:
          {{- toYaml .Values.global.imagePullSecrets | nindent 10 }}
      {{- end }}
    labels:
      release-group: services

  - name: llm-request-router
    chart: nvcf/helm-nvcf-llm-request-router
    version: 1.2.1
    namespace: nvcf
    condition: addons.llm.enabled
    values:
      - ../global.yaml.gotmpl
    needs:
      - nvcf/api
    labels:
      release-group: services

  - name: llm-api-gateway
    chart: nvcf/helm-nvcf-llm-api-gateway
    version: 1.1.0
    namespace: nvcf
    condition: addons.llm.enabled
    values:
      - ../global.yaml.gotmpl
    needs:
      - nvcf/llm-request-router
    labels:
      release-group: services

  # --- Gateway API Ingress ---
  - name: ingress
    chart: nvcf/nvcf-gateway-routes
    version: 1.10.0
    needs:
      - nvcf/notary-service
      - api-keys/api-keys
    namespace: {{ .Values.ingress.gatewayApi.controllerNamespace }}
    condition: ingress.gatewayApi.enabled
    values:
      - ../global.yaml.gotmpl
    labels:
      release-group: ingress
