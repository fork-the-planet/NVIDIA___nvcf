# Self-hosted NVCF Configuration
# Copy this file to config.env and fill in your actual values
# Example: cp config.env.sample config.env

# Self-hosted NVCF invocation API key.
# Generate with: nvcf-cli api-key generate --description "multi-node-helm-test"
KEY="your-api-key-here"

# Gateway address of the self-hosted NVCF cluster.
# Get with: kubectl get gateway nvcf-gateway -n envoy-gateway -o jsonpath='{.status.addresses[0].value}'
GATEWAY_ADDR="your-gateway-address-here"

# Your Function ID
# Uncomment one of these based on your deployment:
# FUNCTION_ID="your-single-node-function-id"
FUNCTION_ID="your-multi-node-function-id"
