{
  "name": "function-with-secret-values",
  "containerImage": "nvcr.io/0651155215864979/ncp-dev/load_tester_supreme:0.0.8",
  "inferenceUrl": "/echo",
  "inferencePort": 8000,
  "description": "Function demonstrating secrets with actual values (OpenAPI compliant)",
  "tags": ["secrets", "example"],
  "functionType": "DEFAULT",
  "apiBodyFormat": "CUSTOM",
  "health": {
    "protocol": "HTTP",
    "uri": "/health",
    "port": 8000,
    "timeout": "PT30S",
    "expectedStatusCode": 200
  },
  "secrets": [
    {
      "name": "api-key",
      "value": "sk-1234567890abcdef"
    },
    {
      "name": "database-config",
      "value": {
        "host": "db.example.com",
        "port": 5432,
        "database": "myapp",
        "ssl": true
      }
    },
    {
      "name": "feature-flags",
      "value": {
        "enable_caching": true,
        "max_batch_size": 32,
        "timeout_seconds": 30
      }
    }
  ],
  "authorizedParties": [
    {
      "ncaId": "nvcf-default"
    }
  ]
}
