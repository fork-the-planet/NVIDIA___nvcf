load("@rules_go//go:def.bzl", "go_library", "go_test")

# skilldata_generated.go is checked in (see //go:generate in install.go). From
# this directory run: go generate ./...
# Or from src/clis/nvcf-cli: go generate ./internal/agentskill/...

go_library(
    name = "agentskill",
    srcs = [
        "install.go",
        "manifest.go",
        "skilldata_generated.go",
    ],
    importpath = "nvcf-cli/internal/agentskill",
    visibility = ["//src/clis/nvcf-cli:__subpackages__"],
)

go_test(
    name = "agentskill_test",
    srcs = [
        "install_test.go",
        "manifest_test.go",
    ],
    embed = [":agentskill"],
)
