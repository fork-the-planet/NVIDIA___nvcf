# ============================================================================
# Bazel configuration for ess-agent.
#
# Bazel scaffold for this monorepo subtree. See BAZEL.md and
# docs/bazel-rollout.md for the shared wiring.
# ============================================================================

build --compilation_mode=fastbuild
common --enable_bzlmod
build --incompatible_strict_action_env
common --enable_platform_specific_config

common --incompatible_enable_proto_toolchain_resolution

test --test_output=errors
test --test_env=HOME=/tmp
test --test_env=XDG_CACHE_HOME=/tmp/.cache

startup --host_jvm_args=-Xmx2g

# ---- Workspace status (build stamping) ----
# Feeds tools/workspace_status.sh keys (STABLE_VERSION, STABLE_GIT_COMMIT,
# STABLE_OCI_TAG, ...) into stamped binaries and OCI image tags. Used by
# the go_oci_image push target so the image carries `latest`, the version
# tag, and the commit SHA. `--stamp` is opt-in at the build invocation;
# without it, only volatile keys (BUILD_DATE) get refreshed.
build --workspace_status_command=tools/workspace_status.sh

# ---- Go ----
# Pure Go (no cgo). Matches the Dockerfile (CGO_ENABLED=0 implied) so
# Bazel binaries match the existing go-build artifacts.
build --@rules_go//go/config:pure

# ---- CI profile ----
build:ci --jobs=16

# ---- Debug / release profiles ----
build:debug --compilation_mode=dbg
build:debug -s
build:release --compilation_mode=opt
build:release --strip=always
