"""Bzlmod module definition for byoo-otel-collector.

Two Go modules in this repo:
1. Root go.mod -- the byoo-otel-collector wrapper (cmd/byoo-otel-collector
   plus internal/* helpers). Plain Go, no codegen.
2. otelcol/go.mod -- the OpenTelemetry Collector binary. Generated by
   ocb (go.opentelemetry.io/collector/cmd/builder) from
   otel-collector-build.yaml, checked into the repo. See
   scripts/regenerate-otelcol.sh and tools/ci/check-otelcol-generated.

Both modules are wired into Gazelle via the go.work below. Each becomes
a separate go_binary; the multi-arch OCI images that consume them are
declared in //:BUILD.bazel.

The umbrella nvcf/nvcf consumes this subtree under
src/compute-plane-services/byoo-otel-collector; this file is also picked up
there but the umbrella's own root MODULE.bazel is what Bazel uses end-to-end.
"""

module(
    name = "byoo_otel_collector",
    version = "0.0.1",
)

# ============================================================================
# OCI containers (multi-arch). Mirrors the canonical Phase B scaffold.
# ============================================================================
bazel_dep(name = "platforms", version = "1.0.0")
bazel_dep(name = "rules_oci", version = "2.2.7")
bazel_dep(name = "rules_pkg", version = "1.2.0")
bazel_dep(name = "aspect_bazel_lib", version = "2.19.3")
bazel_dep(name = "hermetic_cc_toolchain", version = "4.1.0")

# rules_pkg's pkg_tar runs through a Python builder, which pulls in
# rules_python's hermetic interpreter. CI runs as root in the bazel-ci
# container, and rules_python rejects root-user setup by default.
bazel_dep(name = "rules_python", version = "1.4.1")

python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    ignore_root_user_error = True,
    python_version = "3.11",
)

# ============================================================================
# Go. Two modules wired through go.work. Gazelle's go_deps extension
# discovers both go.mod files from the workspace and unifies the
# external dep graph; per-package BUILD.bazel files (generated by
# `bazel run //:gazelle`) reference the unified `@gazelle++go_deps+...`
# repos.
# ============================================================================
bazel_dep(name = "rules_go", version = "0.60.0")
bazel_dep(name = "gazelle", version = "0.48.0")

go_sdk = use_extension("@rules_go//go:extensions.bzl", "go_sdk")
go_sdk.download(version = "1.25.6")

go_deps = use_extension("@gazelle//:extensions.bzl", "go_deps")
go_deps.from_file(go_work = "//:go.work")

# Auto-managed by `bazel mod tidy`. Re-run after adding or removing
# imports. The list below is conservative; tidy will reconcile against
# the actual transitive closure of both go.mod files.
use_repo(
    go_deps,
    "com_github_cenkalti_backoff_v4",
    "com_github_google_go_cmp",
    "com_github_kelseyhightower_envconfig",
    "com_github_open_telemetry_opentelemetry_collector_contrib_exporter_azuremonitorexporter",
    "com_github_open_telemetry_opentelemetry_collector_contrib_exporter_datadogexporter",
    "com_github_open_telemetry_opentelemetry_collector_contrib_exporter_prometheusremotewriteexporter",
    "com_github_open_telemetry_opentelemetry_collector_contrib_exporter_splunkhecexporter",
    "com_github_open_telemetry_opentelemetry_collector_contrib_extension_basicauthextension",
    "com_github_open_telemetry_opentelemetry_collector_contrib_extension_bearertokenauthextension",
    "com_github_open_telemetry_opentelemetry_collector_contrib_extension_cgroupruntimeextension",
    "com_github_open_telemetry_opentelemetry_collector_contrib_extension_healthcheckextension",
    "com_github_open_telemetry_opentelemetry_collector_contrib_extension_healthcheckv2extension",
    "com_github_open_telemetry_opentelemetry_collector_contrib_extension_oauth2clientauthextension",
    "com_github_open_telemetry_opentelemetry_collector_contrib_processor_attributesprocessor",
    "com_github_open_telemetry_opentelemetry_collector_contrib_processor_filterprocessor",
    "com_github_open_telemetry_opentelemetry_collector_contrib_processor_k8sattributesprocessor",
    "com_github_open_telemetry_opentelemetry_collector_contrib_processor_metricstransformprocessor",
    "com_github_open_telemetry_opentelemetry_collector_contrib_processor_resourcedetectionprocessor",
    "com_github_open_telemetry_opentelemetry_collector_contrib_processor_resourceprocessor",
    "com_github_open_telemetry_opentelemetry_collector_contrib_processor_transformprocessor",
    "com_github_open_telemetry_opentelemetry_collector_contrib_receiver_k8seventsreceiver",
    "com_github_open_telemetry_opentelemetry_collector_contrib_receiver_prometheusreceiver",
    "com_github_prometheus_client_golang",
    "com_github_spf13_cobra",
    "com_github_spf13_pflag",
    "com_github_stretchr_testify",
    "in_gopkg_yaml_v3",
    "io_opentelemetry_go_collector_component",
    "io_opentelemetry_go_collector_confmap",
    "io_opentelemetry_go_collector_confmap_provider_envprovider",
    "io_opentelemetry_go_collector_confmap_provider_fileprovider",
    "io_opentelemetry_go_collector_confmap_provider_httpprovider",
    "io_opentelemetry_go_collector_confmap_provider_httpsprovider",
    "io_opentelemetry_go_collector_confmap_provider_yamlprovider",
    "io_opentelemetry_go_collector_connector",
    "io_opentelemetry_go_collector_exporter",
    "io_opentelemetry_go_collector_exporter_debugexporter",
    "io_opentelemetry_go_collector_exporter_otlpexporter",
    "io_opentelemetry_go_collector_exporter_otlphttpexporter",
    "io_opentelemetry_go_collector_extension",
    "io_opentelemetry_go_collector_otelcol",
    "io_opentelemetry_go_collector_processor",
    "io_opentelemetry_go_collector_processor_batchprocessor",
    "io_opentelemetry_go_collector_processor_memorylimiterprocessor",
    "io_opentelemetry_go_collector_receiver",
    "io_opentelemetry_go_collector_receiver_otlpreceiver",
    "io_opentelemetry_go_collector_service",
    "org_golang_x_sys",
    "org_uber_go_zap",
)

# ============================================================================
# C++ cross-compilation (multi-arch container builds).
# ============================================================================
zig = use_extension("@hermetic_cc_toolchain//toolchain:ext.bzl", "toolchains")
use_repo(zig, "zig_sdk")

register_toolchains(
    "@zig_sdk//toolchain:linux_arm64_gnu.2.38",
)

# ============================================================================
# OCI base image. Same hardened distroless/go pin used by other Phase B
# Go services (ess-agent, nats-auth-callout, etc.). The current
# Dockerfile uses golang:bookworm + distroless/go:v4.0.4; for Bazel we
# move to the hardened mirror to match the rest of the fleet.
# ============================================================================
oci = use_extension("@rules_oci//oci:extensions.bzl", "oci")
oci.pull(
    name = "distroless_go",
    digest = "sha256:6be4473eca4e8a5fdf8d7103a4d35708f5538bb5f7a58f0d12a257bdf362334f",
    image = "urm.nvidia.com/sw-gpu-ucs-hardened-docker/distroless/go",
    platforms = [
        "linux/amd64",
        "linux/arm64/v8",
    ],
    www_authenticate_challenges = {
        "urm.nvidia.com": "Bearer realm=\"https://urm.nvidia.com/artifactory/api/docker/null/v2/token\",service=\"urm.nvidia.com\",scope=\"repository:{repository}:pull\"",
    },
)
use_repo(
    oci,
    "distroless_go",
    "distroless_go_linux_amd64",
    "distroless_go_linux_arm64_v8",
)
