receivers:
  otlp:
    protocols:
      grpc:
        endpoint: "${env:OTEL_POD_IP:-0.0.0.0}:14357"
      http:
        endpoint: "${env:OTEL_POD_IP:-0.0.0.0}:14358"

  prometheus:
    config:
      scrape_configs:
        - job_name: "nvcf-worker"
          scrape_interval: 30s
          scrape_timeout: 25s
          honor_labels: true
          metrics_path: "/federate"
          static_configs:
            - targets:
              - "nvcf-byoo-prometheus-kube-prometheus.monitoring.svc.cluster.local:9090"
          params:
            "match[]":
              - '{job=~"nvcf-worker", namespace=~"{{ .Namespace }}", __name__=~"(nvcf_worker_service_request_total|nvcf_worker_service_response_total|nvcf_worker_service_stream_streaming_app_ready|nvcf_worker_service_stream_streaming_app_ready_timestamp|nvcf_worker_service_stream_session_duration_seconds_bucket|nvcf_worker_service_stream_session_duration_seconds_count|nvcf_worker_service_stream_session_duration_seconds_sum|nvcf_worker_service_inference_request_time_seconds_total|nvcf_worker_service_inference_uploads_total|nvcf_worker_service_inference_bytes_total|nvcf_worker_service_inference_failure_total|nvcf_worker_service_worker_thread_count_total|nvcf_worker_service_worker_thread_busy_seconds_total|nvcf_worker_service_bytes_total|nvcf_worker_service_request_latency_seconds_bucket|nvcf_worker_service_request_latency_seconds_sum|nvcf_worker_service_request_latency_seconds_count|nvcf_worker_service_stream_latency_seconds_bucket|nvcf_worker_service_stream_latency_seconds_sum|nvcf_worker_service_stream_latency_seconds_count|nvct_worker_service_result_total|nvcf_worker_service_stream_active)"}'
          metric_relabel_configs:
            - action: labelkeep
              regex: "(__name__|container|job|pod|error_code|le)"
        - job_name: "nvca"
          scrape_interval: 30s
          scrape_timeout: 25s
          honor_labels: true
          metrics_path: "/federate"
          static_configs:
            - targets:
              - "nvcf-byoo-prometheus-kube-prometheus.monitoring.svc.cluster.local:9090"
          params:
            "match[]":
              - '{job=~"nvca", namespace="nvca-system", pod=~"nvca.*", container="agent", __name__=~"(nvca_instance_type_allocatable|nvca_instance_type_capacity)"}'
          metric_relabel_configs:
            - action: labelkeep
              regex: "(__name__|instance_type|nvca_cluster_group|nvca_cluster_name|nvca_nca_id|nvca_version|job|pod)"
        - job_name: "kubernetes-cadvisor"
          scrape_interval: 30s
          scrape_timeout: 25s
          honor_labels: true
          honor_timestamps: false
          metrics_path: "/federate"
          static_configs:
            - targets:
              - "nvcf-byoo-prometheus-kube-prometheus.monitoring.svc.cluster.local:9090"
          params:
            "match[]":
              # kubelet (relabel rules aligned with byoo-prometheus servicemonitor_kubelet.yaml)
              - '{job=~"kubelet", namespace=~"{{ .Namespace }}", __name__=~"(container_cpu_cfs_throttled_periods_total|container_cpu_cfs_throttled_seconds_total|container_cpu_usage_seconds_total|container_memory_cache|container_memory_rss|container_memory_swap|container_memory_usage_bytes|container_memory_working_set_bytes|container_fs_limit_bytes|container_fs_usage_bytes|container_fs_reads_total|container_fs_writes_total|container_fs_writes_bytes_total|container_fs_reads_bytes_total|container_network_receive_bytes_total|container_network_receive_errors_total|container_network_receive_packets_dropped_total|container_network_receive_packets_total|container_network_transmit_bytes_total|container_network_transmit_errors_total|container_network_transmit_packets_dropped_total|container_network_transmit_packets_total)"}'
          metric_relabel_configs:
            # for container_fs_.+ metrics
            - source_labels: [device]
              regex: '(^$|/dev/root|/dev/shm|/run)'
              action: keep
            # rename the job to kubernetes-cadvisor
            - source_labels: [job]
              regex: "kubelet"
              replacement: "kubernetes-cadvisor"
              target_label: job
            - source_labels: [pod]
              regex: "(utils|nvcf-smb-server)"
              action: drop
            - source_labels: [container]
              regex: "(byoo-otel-collector|utils|ess)"
              action: drop
            - action: labelkeep
              regex: "(__name__|container|cpu|device|image|job|interface|pod)"
        - job_name: "kube-state-metrics"
          scrape_interval: 30s
          scrape_timeout: 25s
          honor_labels: true
          metrics_path: "/federate"
          static_configs:
            - targets:
              - "nvcf-byoo-prometheus-kube-prometheus.monitoring.svc.cluster.local:9090"
          params:
            "match[]":
              # kube-state-metrics (relabel rules aligned with byoo-prometheus servicemonitor_kube-state-metrics.yaml)
              - '{job=~"kube-state-metrics", namespace=~"{{ .Namespace }}", __name__=~"kube_deployment_status_condition|kube_deployment_status_replicas|kube_deployment_status_replicas_available|kube_deployment_status_replicas_ready|kube_deployment_status_replicas_unavailable|kube_deployment_status_replicas_updated|kube_service_created|kube_replicaset_status_replicas|kube_replicaset_status_ready_replicas|kube_statefulset_status_replicas|kube_statefulset_status_replicas_ready|kube_job_status_active|kube_job_status_failed|kube_job_status_succeeded|kube_cronjob_status_active|kube_configmap_created|kube_secret_created|kube_pod_container_info|kube_pod_container_resource_limits|kube_pod_container_resource_requests|kube_pod_container_status_last_terminated_exitcode|kube_pod_container_status_last_terminated_reason|kube_pod_container_status_restarts_total|kube_pod_container_status_running|kube_pod_container_status_terminated|kube_pod_container_status_terminated_reason|kube_pod_container_status_waiting|kube_pod_container_status_waiting_reason|kube_pod_container_status_ready|kube_pod_container_state_started|kube_pod_info|kube_pod_status_reason|kube_pod_created|kube_pod_start_time|kube_pod_status_ready_time|kube_pod_init_container_info|kube_pod_init_container_status_ready|kube_pod_init_container_status_restarts_total|kube_pod_init_container_status_running|kube_pod_init_container_last_status_terminated_reason|kube_pod_init_container_status_waiting_reason|kube_pod_init_container_status_waiting"}'
          metric_relabel_configs:
            - source_labels: [pod]
              regex: ".*kube-state-metrics.*"
              replacement: ""
              target_label: pod
            - source_labels: [container]
              regex: ".*kube-state-metrics.*"
              replacement: ""
              target_label: container
            - source_labels: [service]
              regex: ".*kube-state-metrics.*"
              replacement: ""
              target_label: service
            - source_labels: [pod]
              regex: "(utils|nvcf-smb-server)"
              action: drop
            - source_labels: [image]
              regex: "(.*nvcf_worker_init.*)"
              action: drop
            - source_labels: [container]
              regex: "(byoo-otel-collector|ess|ess-init|gxcache-lib-install|nvcf-cert-inject|utils|a-toolbox|fast-merge-certs)"
              action: drop
            - source_labels: [configmap]
              regex: "(byoo-otel-collector|kube-root-ca.crt)"
              action: drop
            - source_labels: [secret]
              regex: "(helm-chart-download|inference-container-pull-secret|nvcf-smb-ro-creds|nvcf-smb-rw-creds|sh.helm.release.v1.mini-service.v1|sr-.*-hsec|sr-.*-pull-worker|.*-sr-.*-regcred-.*|.*-crowdstrike-.*|sr-.*-image-creds)"
              action: drop
            - source_labels: [service]
              regex: "(byoo-otel-collector)"
              action: drop
            - action: labelkeep
              regex: "(__name__|condition|configmap|container|created_by_kind|created_by_name|deployment|host_network|image|job|phase|pod|qos_class|reason|replicaset|resource|secret|service|statefulset|status|unit)"
        - job_name: "nvidia-dcgm-exporter"
          scrape_interval: 30s
          scrape_timeout: 25s
          honor_labels: true
          metrics_path: "/federate"
          static_configs:
            - targets:
              - "nvcf-byoo-prometheus-kube-prometheus.monitoring.svc.cluster.local:9090"
          params:
            "match[]":
              # nvidia-dcgm-exporter (relabel rules aligned with byoo-prometheus servicemonitor_dcgm-exporter.yaml)
              - '{job=~"nvidia-dcgm-exporter", exported_namespace=~"{{ .Namespace }}", __name__=~"DCGM_FI_DEV_GPU_UTIL|DCGM_FI_PROF_PIPE_TENSOR_ACTIVE|DCGM_FI_PROF_DRAM_ACTIVE|DCGM_FI_PROF_SM_ACTIVE|DCGM_FI_PROF_SM_OCCUPANCY|DCGM_FI_PROF_PCIE_TX_BYTES|DCGM_FI_PROF_PCIE_RX_BYTES|DCGM_FI_PROF_NVLINK_TX_BYTES|DCGM_FI_PROF_NVLINK_RX_BYTES|DCGM_FI_DEV_POWER_USAGE|DCGM_FI_DEV_VGPU_MEMORY_USAGE"}'
          metric_relabel_configs:
            - action: labelmap
              regex: exported_(.+)
              replacement: $1
            - action: labelkeep
              regex: "(__name__|container|DCGM_FI_DRIVER_VERSION|device|job|modelName|pci_bus_id|pod)"
        - job_name: opentelemetry-collector
          scrape_interval: 30s
          scrape_timeout: 25s
          static_configs:
            - targets:
              - "${env:OTEL_POD_IP:-0.0.0.0}:18888"
          metric_relabel_configs:
            - source_labels: [__name__]
              action: keep
              regex: "(otelcol_exporter_sent_metric_points_total|otelcol_exporter_sent_spans_total|otelcol_exporter_sent_log_records_total|otelcol_exporter_send_failed_log_records_total|otelcol_exporter_send_failed_spans_total|otelcol_exporter_send_failed_metric_points_total|otelcol_processor_incoming_items_total|otelcol_processor_outgoing_items_total|otelcol_receiver_accepted_log_records_total|otelcol_receiver_accepted_metric_points_total|otelcol_receiver_accepted_spans_total|otelcol_receiver_refused_log_records_total|otelcol_receiver_refused_spans_total|otelcol_receiver_refused_metric_points_total)"

processors:
  batch:
    send_batch_size: 4096
    timeout: 400ms
    send_batch_max_size: 8192
  filter/metrics:
    metrics:
      exclude:
        match_type: strict
        metric_names:
          - scrape_duration_seconds
          - scrape_samples_post_metric_relabeling
          - scrape_samples_scraped
          - scrape_series_added
  memory_limiter:
    check_interval: 1s
    limit_percentage: 80
    spike_limit_percentage: 10
  resource: # rm service.instance.id so that instance is not in place
    attributes:
      - key: service.instance.id
        action: delete
  attributes/add-metadata:
    actions:
      - action: insert
        key: nca_id
        value: "${env:NCA_ID:-unknown}"
      - action: insert
        key: cloud_provider
        value: "${env:NVCF_CLOUD_PROVIDER:-unknown}"
      - action: insert
        key: instance_id
        value: "${env:NVCF_INSTANCE_ID:-unknown}"
      - action: insert
        key: host.id
        value: "${env:NVCF_INSTANCE_ID:-unknown}"
      {{- if .FunctionID }}
      - action: insert
        key: function_id
        value: "${env:NVCF_FUNCTION_ID:-unknown}"
      {{ end }}
      {{- if .FunctionID }}
      - action: insert
        key: function_version_id
        value: "${env:NVCF_FUNCTION_VERSION_ID:-unknown}"
      {{ end }}
      {{- if .ZoneName }}
      - action: insert
        key: cloud_region
        value: "{{ .ZoneName }}"
      {{ end }}
      - action: insert
        key: origin
        value: "nvcf-byoo"
      {{- if .TaskID }}
      - action: insert
        key: task_id
        value: "${env:NVCT_TASK_ID:-unknown}"
      {{ end }}

  metricstransform:
    transforms:
      - include: ^.*$
        match_type: regexp
        action: update
        operations:
          - action: add_label
            new_label: nca_id
            new_value: "${env:NCA_ID:-unknown}"
          - action: add_label
            new_label: cloud_provider
            new_value: "${env:NVCF_CLOUD_PROVIDER:-unknown}"
          - action: add_label
            new_label: instance_id
            new_value: "${env:NVCF_INSTANCE_ID:-unknown}"
          - action: add_label
            new_label: host.id
            new_value: "${env:NVCF_INSTANCE_ID:-unknown}"
          {{- if .FunctionID }}
          - action: add_label
            new_label: function_id
            new_value: "${env:NVCF_FUNCTION_ID:-unknown}"
          {{ end }}
          {{- if .FunctionID }}
          - action: add_label
            new_label: function_version_id
            new_value: "${env:NVCF_FUNCTION_VERSION_ID:-unknown}"
          {{ end }}
          {{- if .ZoneName }}
          - action: add_label
            new_label: cloud_region
            new_value: "{{ .ZoneName }}"
          {{ end }}
          - action: add_label
            new_label: origin
            new_value: "nvcf-byoo"
          {{- if .TaskID }}
          - action: add_label
            new_label: task_id
            new_value: "${env:NVCT_TASK_ID:-unknown}"
          {{ end }}

extensions:
  cgroupruntime:
    gomaxprocs:
      enabled: true
    gomemlimit:
      enabled: true
      ratio: 0.8
  healthcheckv2:
    use_v2: true
    component_health:
      include_permanent_errors: true
      include_recoverable_errors: true
      recovery_duration: 1m
    http:
      endpoint: "${env:OTEL_POD_IP:-0.0.0.0}:13133"
      status:
        enabled: true
        path: "/health"
      config:
        enabled: false