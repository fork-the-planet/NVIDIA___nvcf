load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "dependency",
    srcs = [
        "catalog_datacenters.go",
        "catalog_node.go",
        "catalog_nodes.go",
        "catalog_service.go",
        "catalog_services.go",
        "client_set.go",
        "connect_ca.go",
        "connect_leaf.go",
        "dependency.go",
        "errors.go",
        "file.go",
        "health_service.go",
        "kv_get.go",
        "kv_keys.go",
        "kv_list.go",
        "nomad_service.go",
        "nomad_services.go",
        "nomad_var_get.go",
        "nomad_var_list.go",
        "nomad_var_structs.go",
        "nv_errors.go",
        "nv_vault_common.go",
        "set.go",
        "vault_agent_token.go",
        "vault_common.go",
        "vault_list.go",
        "vault_pki.go",
        "vault_read.go",
        "vault_token.go",
        "vault_write.go",
    ],
    importpath = "github.com/hashicorp/consul-template/dependency",
    visibility = ["//visibility:public"],
    deps = [
        "//api",
        "//api/auth/kubernetes",
        "//nv",
        "//version",
        "@com_github_hashicorp_consul_api//:api",
        "@com_github_hashicorp_go_rootcerts//:go-rootcerts",
        "@com_github_hashicorp_nomad_api//:api",
        "@com_github_pkg_errors//:errors",
    ],
)

alias(
    name = "go_default_library",
    actual = ":dependency",
    visibility = ["//visibility:public"],
)

go_test(
    name = "dependency_test",
    srcs = [
        "catalog_datacenters_test.go",
        "catalog_node_test.go",
        "catalog_nodes_test.go",
        "catalog_service_test.go",
        "catalog_services_test.go",
        "client_set_test.go",
        "connect_ca_test.go",
        "connect_leaf_test.go",
        "consul_common_test.go",
        "dependency_test.go",
        "file_test.go",
        "health_service_test.go",
        "kv_get_test.go",
        "kv_keys_test.go",
        "kv_list_test.go",
        "nomad_service_test.go",
        "nomad_services_test.go",
        "nomad_var_get_test.go",
        "nomad_var_list_test.go",
        "vault_agent_token_test.go",
        "vault_common_test.go",
        "vault_list_test.go",
        "vault_pki_test.go",
        "vault_read_test.go",
        "vault_token_test.go",
        "vault_write_test.go",
    ],
    embed = [":dependency"],
    # Integration test. TestMain spawns real `consul`, `vault`, and
    # `nomad` binaries; in environments without those on PATH the
    # test hangs and times out (315s wall in GitHub Actions on the
    # public NVCF mirror, where the bazel-ci toolchain image
    # intentionally does not ship the HashiCorp binaries due to BSL
    # licensing on post-Aug-2023 releases). Marked manual so
    # `bazel test //...` skips it. Run explicitly with the binaries
    # available, e.g.
    #   bazel test //dependency:dependency_test
    # on a host that has consul + vault + nomad on PATH.
    tags = ["manual"],
    deps = [
        "//api",
        "//renderer",
        "//test",
        "@com_github_hashicorp_consul_api//:api",
        "@com_github_hashicorp_consul_sdk//testutil",
        "@com_github_hashicorp_nomad_api//:api",
        "@com_github_pkg_errors//:errors",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
