        "storage_request_api_test.go",
        "storagerequest_test.go",
        "types_test.go",
    ],
    data = ["//internal/envtest:crds"],
    embed = [":storage"],
    env_inherit = ["KUBEBUILDER_ASSETS"],
    rundir = ".",
    # external: envtest spins up kube-apiserver + etcd from binaries
    # outside Bazel's hermetic input set. A green run gets cached
    # forever even if the test logic regresses; force fresh execution
    # on every pipeline. requires-kubebuilder is descriptive grouping.
    tags = [
        "external",
        "requires-kubebuilder",
    ],
    x_defs = {
        "github.com/NVIDIA/k8s-dra-driver-gpu/internal/info.version": "v25.8.0",
    },
    deps = [
        "//internal/envtest",
