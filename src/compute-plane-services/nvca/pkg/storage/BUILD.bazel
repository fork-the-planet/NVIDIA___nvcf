go_test(
    name = "storage_test",
    srcs = [
        "cachebackend_samba_test.go",
        "cachebackend_test.go",
        "controller_test.go",
        "modelcache_cleanup_test.go",
        "modelcache_nvmesh_encrypt_test.go",
