#!/usr/bin/env bash
#
# Publishes the Bazel-built tool binaries (discover-gpus,
# export-cluster-pubkeys) to the GitLab generic package registry.
# Replaces the legacy flow that extracted binaries out of the byocdev
# tools docker image; with Bazel owning the tools image, we build the
# binaries directly and upload from bazel-bin.
#
# Required env:
#   PACKAGE_API_URL       e.g. ${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages
#   PACKAGE_REGISTRY_URL  e.g. ${PACKAGE_API_URL}/generic/${CI_PROJECT_NAME}
#   CI_JOB_TOKEN          GitLab-provided job token
#   EGX_VERSION           version string used as the package version
#
# Optional env:
#   BAZEL_REMOTE_FLAGS, BAZEL_DISK_CACHE, BAZEL_REPO_CACHE  (passed through if set)

set -euo pipefail

: "${PACKAGE_API_URL}"
: "${PACKAGE_REGISTRY_URL}"
: "${CI_JOB_TOKEN}"
: "${EGX_VERSION}"

binaries=(
  "//cmd/discover-gpus:discover-gpus"
  "//cmd/export-cluster-pubkeys:export-cluster-pubkeys"
)

bazel build \
  ${BAZEL_REMOTE_FLAGS:-} \
  ${BAZEL_DISK_CACHE:+--disk_cache=$BAZEL_DISK_CACHE} \
  ${BAZEL_REPO_CACHE:+--repository_cache=$BAZEL_REPO_CACHE} \
  "${binaries[@]}"

for target in "${binaries[@]}"; do
  name=${target##*:}
  binpath="bazel-bin/cmd/${name}/${name}_/${name}"
  if [ ! -x "${binpath}" ]; then
    echo "expected bazel output not found: ${binpath}" >&2
    exit 1
  fi
  upload_url="${PACKAGE_REGISTRY_URL}/${EGX_VERSION}/${name}"
  echo "Uploading ${name} (${binpath}) -> ${upload_url}"
  curl --fail --silent --show-error \
    -H "JOB-TOKEN: ${CI_JOB_TOKEN}" \
    --upload-file "${binpath}" \
    "${upload_url}"
  echo
done
