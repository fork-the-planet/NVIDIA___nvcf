# ============================================================================
# nvsnap Bazel configuration (standalone repo; not part of the NVCF umbrella)
# ============================================================================

# Per-user overrides (not checked in).
try-import %workspace%/user.bazelrc
try-import %user.home%/.bazelrc.user

build --compilation_mode=fastbuild
common --enable_bzlmod
build --incompatible_strict_action_env
common --enable_platform_specific_config

# Hermetic Go toolchain via rules_go. Disable goroot detection so the
# host's Go does not leak into the build.
build --@rules_go//go/config:pure

# Reproducible-ish image tags via tools/workspace_status.sh.
build --workspace_status_command=tools/workspace_status.sh

# CI profile: same as default but verbose on failure for debug-after-fail.
build:ci --verbose_failures
build:ci --show_progress_rate_limit=5
build:ci --test_output=errors

# Image push profile: stamps version into the image tag from
# workspace_status (STABLE_VERSION).
build:release --stamp

# ============================================================================
# Caching
# ============================================================================
#
# Two tiers:
#
# 1. Disk cache (default-on, workspace-relative). Persists action
#    outputs across same-runner Bazel invocations. CI persists
#    .bazel-cache/ via the gitlab cache: blocks in .gitlab-ci.yml so
#    a second pipeline on the same runner skips work the first one
#    already did. Devs benefit too; the path is gitignored.
#
# 2. Remote cache (opt-in via --config=remote). Points at nvcfbarn,
#    the team Buildbarn at NVIDIA. Default is OFF in this repo
#    because the nvsnap project has no probe wired yet -- enabling
#    --config=remote on a runner that cannot reach nvcfbarn fails
#    the build hard (Bazel's initial GetCapabilities RPC is not
#    covered by --remote_local_fallback). CI sets
#    --config=remote-write explicitly in .gitlab-ci.yml; devs and
#    ad-hoc builds stay on disk-only.
build --disk_cache=.bazel-cache/disk
build --repository_cache=.bazel-cache/repo

# Read-only remote cache profile. Pulls hits from nvcfbarn but does
# not upload. Layer on top of this with --config=remote-write to
# also write back results.
build:remote --remote_cache=grpc://nvcfbarn.nvidia.com:8980
build:remote --remote_upload_local_results=false
build:remote --remote_cache_compression
build:remote --remote_local_fallback

# Write profile, layered on top of read-only. Used by CI's bazel job
# after the toolchain image is in place.
build:remote-write --config=remote
build:remote-write --remote_upload_local_results=true
build:remote-write --remote_cache_async=true
