# GPUCR Credentials Example
# Copy this file to ~/.gpucr/credentials and fill in your values
#
# Required for deploy-agent.sh and install-criu.sh scripts

SSH_USER=your_username
SSH_PASS=your_password

# Optional: Path to cuda-checkpoint binary
# CUDA_CHECKPOINT_PATH=/path/to/cuda-checkpoint

# Optional: Path to forked CRIU source (defaults to ../criu relative to gpucr)
# CRIU_FORK_SRC=/path/to/criu-fork
