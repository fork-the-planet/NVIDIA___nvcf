FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    software-properties-common \
    && add-apt-repository -y ppa:deadsnakes/ppa \
    && apt-get update \
    && apt-get install -y \
        build-essential \
        python3.12 \
        python3.12-venv \
        python3.12-dev \
        python3-pip \
    && rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1 \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1

RUN python3.12 -m ensurepip --upgrade && python3.12 -m pip install --upgrade pip

ENV CFLAGS="-O0 -g"

RUN python3.12 -m pip install --no-cache-dir uvloop aiohttp

WORKDIR /app
COPY tests/uvloop-mp-test/app.py /app/app.py
COPY tests/uvloop-mp-test/sitecustomize.py /app/sitecustomize.py

EXPOSE 8000
CMD ["python3.12", "/app/app.py"]
