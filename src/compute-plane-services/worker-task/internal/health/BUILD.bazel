)

alias(
    name = "go_default_library",
    actual = ":health",
    visibility = ["//:__subpackages__"],
)

go_test(
    name = "health_test",
    srcs = ["health_test.go"],
    embed = [":health"],
    deps = [
        "@com_github_nvidia_nvcf_src_libraries_go_worker//nvct",
        "@com_github_nvidia_nvcf_src_libraries_go_worker//proto/nvct",
    ],
)
