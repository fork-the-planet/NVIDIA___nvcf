# Allowlist for GitLab -> GitHub copy.
# Same format as .gitignore; only paths matching a pattern below are copied.
#
# This is an opt-in mirror list for the OSS-safe repo contents. GitLab-only CI
# (for example .gitlab-ci.yml, pipelines/, .components.yaml) and internal/local
# metadata that should stay private (for example .env) are intentionally
# omitted and not listed here.

# GitHub and repo metadata
.gitignore
.allowed-licenses.txt
.dockerignore
.golangci.yml
.license-baseline.txt
.oss-allowlist
Makefile
README.md
go.mod
go.sum

# Source, packaging, docs, examples, and tests
api-tests/**
cmd/**
deploy/**
docker/**
examples/**
pkg/**
reval/**
scripts/**
test/**
vendor/**

# Bazel scaffold. Mirrored to GitHub so OSS users can `bazel build //...`
# and `bazel test //...` against the same sources we build internally.
# BUILD.bazel and *.bzl under cmd/, pkg/, vendor/, etc. are already
# covered by the **-style allowlist rules above; the entries below cover
# the top-level files that no glob otherwise matches.
.bazelrc
.bazelversion
.bazelignore
MODULE.bazel
MODULE.bazel.lock
BUILD.bazel
rules/**
platforms/**
tools/workspace_status.sh
