load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")
load("//rules/oci:defs.bzl", "go_oci_image")

go_library(
    name = "reval-service_lib",
    srcs = ["main.go"],
    importpath = "github.com/NVIDIA/nvcf/src/control-plane-services/helm-reval/cmd/reval-service",
    visibility = ["//visibility:private"],
    deps = [
        "//cmd/reval/cli",
        "//pkg/authorizers",
        "//pkg/reval/config",
        "//pkg/telemetry/logging",
        "@com_github_spf13_viper//:viper",
        "@org_uber_go_zap//:zap",
    ],
)

go_binary(
    name = "reval-service",
    embed = [":reval-service_lib"],
    visibility = ["//visibility:public"],
    # Mirrors the legacy Dockerfile ldflags: -X version.{Version,GitHash,ReleaseTag}.
    x_defs = {
        "github.com/NVIDIA/nvcf/src/libraries/go/lib/pkg/version.Version": "{STABLE_VERSION}",
        "github.com/NVIDIA/nvcf/src/libraries/go/lib/pkg/version.GitHash": "{STABLE_GIT_COMMIT}",
        "github.com/NVIDIA/nvcf/src/libraries/go/lib/pkg/version.ReleaseTag": "{STABLE_OCI_TAG}",
    },
)

# Multi-arch OCI image. Distroless/go base, binary at /usr/bin/reval-service.
# Build/load/index/tar targets live here. The internal NGC publish lanes
# (kaze, nv-ngc-devops, ncp-dev) are defined under //nvidia-internal:*
# so the registry coordinates stay out of the public OSS snapshot.
go_oci_image(
    name = "image",
    base = "@distroless_go",
    binary = ":reval-service",
    binary_path = "/usr/bin/reval-service",
    tags = ["nvcf-helm-reval-api"],
    visibility = ["//visibility:public"],
)

sh_test(
    name = "image_entrypoint_mode_test",
    srcs = ["image_entrypoint_mode_test.sh"],
    args = ["$(location :image.tar)"],
    data = [":image.tar"],
)

go_test(
    name = "reval-service_test",
    srcs = ["main_test.go"],
    embed = [":reval-service_lib"],
    deps = [
        "//pkg/authorizers",
        "//pkg/reval/config",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
