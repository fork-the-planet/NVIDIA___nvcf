    visibility = ["//visibility:public"],
)

go_test(
    name = "config_test",
    srcs = ["files_test.go"],
    deps = [
        ":config",
        "@com_github_spf13_viper//:viper",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@org_uber_go_zap//:zap",
    ],
