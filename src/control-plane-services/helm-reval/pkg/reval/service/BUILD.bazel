load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "service",
    srcs = [
        "models.go",
        "service.go",
    ],
    importpath = "github.com/NVIDIA/nvcf/src/control-plane-services/helm-reval/pkg/reval/service",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/httpapi",
        "//reval",
        "@com_github_go_chi_render//:render",
