        "models_test.go",
        "service_test.go",
    ],
    embed = [":service"],
    deps = [
        "//reval",
        "@com_github_go_chi_render//:render",
        "@com_github_nvidia_nvcf_src_libraries_go_lib//pkg/icms-translate/translate/common",
