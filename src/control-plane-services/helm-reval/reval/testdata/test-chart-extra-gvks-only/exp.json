[
    {
        "apiVersion": "nvidia.com/v1alpha1",
        "kind": "DynamoGraphDeployment",
        "metadata": {
            "name": "nvcf-dynamo-disagg-router"
        },
        "spec": {
            "services": {
                "Frontend": {
                    "componentType": "frontend",
                    "replicas": 1,
                    "extraPodSpec": {
                        "mainContainer": {
                            "image": "nvcr.io/nvidia/ai-dynamo/vllm-runtime:0.9.0"
                        }
                    },
                    "envs": [
                        {
                            "name": "DYN_ROUTER_MODE",
                            "value": "kv"
                        }
                    ]
                },
                "VllmDecodeWorker": {
                    "componentType": "worker",
                    "replicas": 2,
                    "resources": {
                        "limits": {
                            "gpu": 1
                        }
                    },
                    "extraPodSpec": {
                        "mainContainer": {
                            "image": "nvcr.io/nvidia/ai-dynamo/vllm-runtime:0.9.0",
                            "workingDir": "/workspace/examples/backends/vllm",
                            "command": [
                                "python3",
                                "-m",
                                "dynamo.vllm"
                            ],
                            "args": [
                                "--model",
                                "Qwen/Qwen3-0.6B",
                                "--is-decode-worker"
                            ]
                        }
                    }
                },
                "VllmPrefillWorker": {
                    "componentType": "worker",
                    "replicas": 2,
                    "resources": {
                        "limits": {
                            "gpu": 1
                        }
                    },
                    "extraPodSpec": {
                        "mainContainer": {
                            "image": "nvcr.io/nvidia/ai-dynamo/vllm-runtime:0.9.0",
                            "workingDir": "/workspace/examples/backends/vllm",
                            "command": [
                                "python3",
                                "-m",
                                "dynamo.vllm"
                            ],
                            "args": [
                                "--model",
                                "Qwen/Qwen3-0.6B",
                                "--is-prefill-worker"
                            ]
                        }
                    }
                }
            }
        }
    }
]
