load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "proxy",
    srcs = [
        "director.go",
        "h1.go",
        "h2.go",
        "h3.go",
        "health.go",
        "hijack.go",
        "proxy.go",
        "tracing.go",
    ],
    importpath = "nvcf-grpc-proxy/proxy",
    visibility = ["//visibility:public"],
    deps = [
        "//nvcf/pb",
        "//proxy/consts",
        "//proxy/credentials",
