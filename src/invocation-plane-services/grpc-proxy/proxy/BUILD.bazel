        "//proxy/quicconn",
        "//proxy/ratelimit",
        "//proxy/reloadableTls",
        "//proxy/worker",
        "@com_github_carlmjohnson_versioninfo//:versioninfo",
        "@com_github_go_chi_cors//:cors",
        "@com_github_google_uuid//:uuid",
        "@com_github_hellofresh_health_go_v5//:health-go",
        "@com_github_jellydator_ttlcache_v3//:ttlcache",
        "@com_github_nats_io_nats_go//:nats_go",
        "@com_github_nvidia_nvcf_go//pkg/nvkit/auth",
        "@com_github_nvidia_nvcf_go//pkg/nvkit/clients",
        "@com_github_nvidia_nvcf_go//pkg/nvkit/errors",
        "@com_github_nvidia_nvcf_go//pkg/nvkit/logs",
        "@com_github_nvidia_nvcf_go//pkg/nvkit/servers",
        "@com_github_nvidia_nvcf_go//pkg/nvkit/tracing",
        "@com_github_quic_go_quic_go//:quic-go",
        "@com_github_quic_go_quic_go//http3",
        "@com_github_samber_lo//:lo",
        "@io_opentelemetry_go_otel//:otel",
