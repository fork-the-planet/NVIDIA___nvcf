load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "geo",
    srcs = [
        "geo.go",
        "glps.go",
        "s3.go",
    ],
    importpath = "nvcf-grpc-proxy/proxy/geo",
    visibility = ["//visibility:public"],
    deps = [
        "@com_github_aws_aws_sdk_go_v2//aws",
        "@com_github_aws_aws_sdk_go_v2_config//:config",
        "@com_github_aws_aws_sdk_go_v2_service_s3//:s3",
        "@com_github_goccy_go_json//:go-json",
        "@com_github_nvidia_nvcf_go//pkg/nvkit/auth",
        "@com_github_nvidia_nvcf_go//pkg/nvkit/clients",
        "@io_opentelemetry_go_contrib_instrumentation_github_com_aws_aws_sdk_go_v2_otelaws//:otelaws",
        "@org_uber_go_zap//:zap",
    ],
)

alias(
    name = "go_default_library",
    actual = ":geo",
    visibility = ["//visibility:public"],
)

go_test(
    name = "geo_test",
    srcs = [
        "geo_test.go",
        "glps_test.go",
    ],
    embed = [":geo"],
    # geo_test.go uses testcontainers-go + the localstack module which
    # needs a Docker daemon. Bazel's sandbox + isolation breaks
    # testcontainers' socket discovery, so this target runs with:
    #   - local = True: skip the sandbox so the test process sees the
    #     real network and filesystem (including the Docker socket the
    #     daemon listens on).
    #   - env_inherit: pass the Docker-related env vars through from the
    #     caller (local dev: DOCKER_HOST or /var/run/docker.sock auto-
    #     detect; CI: DOCKER_HOST=tcp://docker:2375 from the dind service
    #     plus the TESTCONTAINERS_HOST_OVERRIDE that makes ryuk reachable).
    #   - tags = ["requires-docker"]: lets ad-hoc callers
    #     `bazel test --test_tag_filters=-requires-docker //...` to skip
    #     this when no Docker is available.
    env_inherit = [
        "PATH",
        "DOCKER_HOST",
        "DOCKER_TLS_CERTDIR",
        "DOCKER_CERT_PATH",
        "DOCKER_TLS_VERIFY",
        "TESTCONTAINERS_HOST_OVERRIDE",
        "TESTCONTAINERS_RYUK_DISABLED",
    ],
    local = True,
    tags = ["requires-docker"],
    deps = [
        "@com_github_aws_aws_sdk_go_v2//aws",
        "@com_github_aws_aws_sdk_go_v2_config//:config",
        "@com_github_aws_aws_sdk_go_v2_credentials//:credentials",
        "@com_github_aws_aws_sdk_go_v2_service_s3//:s3",
        "@com_github_docker_go_connections//nat",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//mock",
        "@com_github_stretchr_testify//require",
        "@com_github_testcontainers_testcontainers_go//:testcontainers-go",
        "@com_github_testcontainers_testcontainers_go_modules_localstack//:localstack",
        "@org_uber_go_zap//:zap",
    ],
)
