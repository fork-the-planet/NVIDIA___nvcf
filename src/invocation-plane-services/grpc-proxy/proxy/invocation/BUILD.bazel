load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "invocation",
    srcs = [
        "function_invoker.go",
        "nats.go",
        "nats_tracing.go",
        "sleep.go",
        "stateful_session_request_registration.go",
    ],
    importpath = "nvcf-grpc-proxy/proxy/invocation",
    visibility = ["//visibility:public"],
    deps = [
        "//nvcf/pb",
        "//proxy/metrics",
        "@com_github_google_uuid//:uuid",
        "@com_github_grpc_ecosystem_go_grpc_middleware//retry",
        "@com_github_nats_io_nats_go//:nats_go",
        "@com_github_nats_io_nats_go//jetstream",
        "@com_github_nats_io_nkeys//:nkeys",
        "@com_github_nvidia_nvcf_go//pkg/nvkit/auth",
        "@com_github_nvidia_nvcf_go//pkg/nvkit/errors",
        "@com_github_samber_lo//:lo",
        "@io_opentelemetry_go_otel//:otel",
        "@io_opentelemetry_go_otel//attribute",
        "@io_opentelemetry_go_otel//propagation",
        "@io_opentelemetry_go_otel_trace//:trace",
        "@org_golang_google_grpc//codes",
        "@org_golang_google_grpc//credentials",
        "@org_golang_google_protobuf//proto",
        "@org_golang_google_protobuf//types/known/timestamppb",
        "@org_uber_go_zap//:zap",
    ],
)

alias(
    name = "go_default_library",
    actual = ":invocation",
    visibility = ["//visibility:public"],
)

go_test(
    name = "invocation_test",
    srcs = ["nats_test.go"],
    embed = [":invocation"],
    deps = [
        "@com_github_nats_io_nkeys//:nkeys",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
