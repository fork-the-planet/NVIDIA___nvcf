set -euo pipefail

export PORT="${PORT:-8080}"
export OLRIC_ENABLED="${OLRIC_ENABLED:-true}"
export OLRIC_ENV="${OLRIC_ENV:-local}"
export STARGATE_URL="${STARGATE_URL:-http://127.0.0.1:8000}"
export NVCF_REGION="${NVCF_REGION:-local}"
export NVCF_DEFAULT_FUNCTION_ID="${NVCF_DEFAULT_FUNCTION_ID:-default}"
export NVCF_DEFAULT_MODEL="${NVCF_DEFAULT_MODEL:-bootstrap-echo}"

exec watchexec \
  --debounce 200ms \
  --shell=none \
  --restart \
  --stop-signal SIGINT \
  --exts go,env,toml \
  go run ./cmd/llm-api-gateway
