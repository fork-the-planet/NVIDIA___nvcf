#!/usr/bin/env bash
#
# This script exits non-zero if the NOTICE file's third-party license list
# is out of sync with the actual vendor license files.
set -eu -o pipefail

repo_root="$(cd "$(dirname "$0")/.." && pwd)"
cd "${repo_root}"

NOTICE_FILE="NOTICE"

# Get expected licenses from vendor directory
expected_licenses=$(find vendor -name "LICENSE*" -type f | sort)

# Get licenses listed in NOTICE file (lines starting with "    vendor/")
listed_licenses=$(grep -E "^    vendor/" "$NOTICE_FILE" 2>/dev/null | sed 's/^    //' | sort || true)

# Compare
if [ "$expected_licenses" != "$listed_licenses" ]; then
    echo "ERROR: NOTICE file third-party list is out of sync with vendor licenses."
    echo ""
    echo "Expected licenses not in NOTICE file:"
    comm -23 <(echo "$expected_licenses") <(echo "$listed_licenses") | head -20
    echo ""
    echo "Licenses in NOTICE file but not in vendor:"
    comm -13 <(echo "$expected_licenses") <(echo "$listed_licenses") | head -20
    echo ""
    echo "Run 'make license-update' to fix this."
    exit 1
fi

if [ -z "$expected_licenses" ]; then
    license_count=0
else
    license_count=$(printf '%s\n' "$expected_licenses" | grep -c '.')
fi

echo "NOTICE file third-party list is up to date ($license_count licenses)."
