{
    "namespace": "my-ns",
    "objectNameBase": "fake-object-name",
    "commonLabels": {
        "lk": "lv"
    },
    "commonAnnotations": {
        "ak": "av"
    },
    "serviceAccountName": "my-sa",
    "sidecarAsDeployment": true,
    "nodeAffinity": {
        "requiredDuringSchedulingIgnoredDuringExecution": {
            "nodeSelectorTerms": [
                {
                    "matchExpressions": [
                        {
                            "key": "my-ns/foo",
                            "operator": "DoesNotExist"
                        }
                    ]
                },
                {
                    "matchExpressions": [
                        {
                            "key": "my-ns/bar",
                            "operator": "In",
                            "values": [
                                "baz"
                            ]
                        }
                    ]
                }
            ]
        }
    },
    "instanceTypeLabelSelectorKey": "nvca.nvcf.nvidia.io/instance-type"
}
