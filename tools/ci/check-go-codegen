set -euo pipefail

usage() {
    cat <<'EOF'
Usage: ./tools/ci/check-go-codegen <module-dir> --command <command> [--install <tool@version>]...

Install any required codegen tools, run the supplied command inside the module,
and fail if generated files change tracked content.
EOF
}

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
module_dir="${1:-}"
effective_gowork="${GOWORK:-off}"
shift || true

if [[ "${module_dir}" == "-h" || "${module_dir}" == "--help" ]]; then
    usage
    exit 0
fi

if [[ -z "${module_dir}" ]]; then
    usage >&2
    exit 1
fi

if [[ "${module_dir}" != /* ]]; then
    module_dir="${repo_root}/${module_dir}"
fi

if [[ ! -f "${module_dir}/go.mod" ]]; then
    echo "missing go.mod under ${module_dir}" >&2
    exit 1
fi

command_string=""
declare -a installs=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --install)
            [[ $# -ge 2 ]] || {
                echo "missing value for --install" >&2
                exit 1
            }
            installs+=("$2")
            shift 2
            ;;
        --command)
            [[ $# -ge 2 ]] || {
                echo "missing value for --command" >&2
                exit 1
            }
            command_string="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "unexpected argument: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
done

if [[ -z "${command_string}" ]]; then
    echo "--command is required" >&2
    exit 1
fi

tool_bin_dir="$(mktemp -d)"
trap 'rm -rf "${tool_bin_dir}"' EXIT

for install_target in "${installs[@]}"; do
    GOWORK="${effective_gowork}" GOBIN="${tool_bin_dir}" go install "${install_target}"
done

cd "${module_dir}"
PATH="${tool_bin_dir}:${PATH}" GOWORK="${effective_gowork}" bash -o pipefail -c "${command_string}"
git status --short -- .
git diff --ignore-space-at-eol --exit-code -- .
