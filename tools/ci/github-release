import argparse
import json
import os
import re
import subprocess
import sys
from pathlib import Path


SEMVER_PATTERN = r"(?:0|[1-9]\d*)\.(?:0|[1-9]\d*)\.(?:0|[1-9]\d*)(?:-(?:rc|dev)\.(?:0|[1-9]\d*))?"
RELEASE_RULES = [
    {"type": "feat", "release": "minor"},
    {"type": "fix", "release": "patch"},
    {"type": "perf", "release": "patch"},
    {"type": "chore", "release": False},
    {"type": "ci", "release": False},
    {"type": "docs", "release": False},
    {"type": "style", "release": False},
    {"type": "refactor", "release": False},
    {"type": "test", "release": False},
    {"type": "build", "release": False},
]
VERSION_PLACEHOLDER = "${version}"
INITIAL_RELEASE_VERSION = "0.1.0"
INITIAL_RELEASE_FLOOR_VERSION = "0.0.0"


def bool_env(name, default=False):
    raw = os.environ.get(name)
    if raw is None or raw == "":
        return default
    return raw.strip().lower() in {"1", "true", "yes", "on"}


def github_release_mode():
    auto_tagging_enabled = bool_env("NVCF_GITHUB_AUTO_TAGGING_ENABLED", False)
    dry_run = bool_env("NVCF_GITHUB_RELEASE_DRY_RUN", not auto_tagging_enabled)
    if not auto_tagging_enabled:
        dry_run = True
    return auto_tagging_enabled, dry_run


def run(args, cwd=None, check=True, capture=False, env=None):
    if capture:
        result = subprocess.run(
            args,
            cwd=cwd,
            env=env,
            check=False,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
        )
        if check and result.returncode != 0:
            sys.stdout.write(result.stdout)
            raise subprocess.CalledProcessError(result.returncode, args)
        return result.stdout

    result = subprocess.run(args, cwd=cwd, env=env, check=False)
    if check and result.returncode != 0:
        raise subprocess.CalledProcessError(result.returncode, args)
    return ""


def stream(args, cwd=None, env=None):
    proc = subprocess.Popen(
        args,
        cwd=cwd,
        env=env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
    )
    output = []
    assert proc.stdout is not None
    for line in proc.stdout:
        output.append(line)
        sys.stdout.write(line)
    return proc.wait(), "".join(output)


def repo_root():
    return Path(run(["git", "rev-parse", "--show-toplevel"], capture=True).strip())


def load_metadata(root, metadata_path):
    path = Path(metadata_path)
    if not path.is_absolute():
        path = root / path
    with path.open() as f:
        metadata = json.load(f)
    if metadata.get("version") != 1:
        raise SystemExit(f"unsupported GitHub release metadata version: {metadata.get('version')}")
    return metadata


def semverish_sort_key(value):
    return [int(part) if part.isdigit() else part for part in re.split(r"(\d+)", value)]


def default_tag_format(service):
    prefix = str(service.get("path") or "").strip().strip("/")
    if prefix and prefix != ".":
        return f"{prefix}/v{VERSION_PLACEHOLDER}"
    return f"v{VERSION_PLACEHOLDER}"


def tag_format(service):
    return service.get("tag_format") or default_tag_format(service)


def tag_prefix(service):
    value = tag_format(service)
    if not value.endswith(VERSION_PLACEHOLDER):
        raise SystemExit(f"{service['id']}: tag_format must end with {VERSION_PLACEHOLDER}: {value}")
    return value[: -len(VERSION_PLACEHOLDER)]


def tag_prefixes(service):
    prefixes = [tag_prefix(service)]
    legacy = (service.get("legacy_tag_prefix") or "").strip()
    if legacy and legacy not in prefixes:
        prefixes.append(legacy)
    return prefixes


def tag_for_version(service, version):
    return tag_format(service).replace(VERSION_PLACEHOLDER, version, 1)


def find_service(metadata, selector):
    for service in metadata.get("services", []):
        if selector in {service.get("id", ""), service.get("service_name", ""), service.get("path", "")}:
            return service
    choices = ", ".join(sorted(s.get("id", "") for s in metadata.get("services", []) if s.get("id")))
    raise SystemExit(f"unknown service {selector!r}; expected one of: {choices}")


def version_from_tag(service, tag):
    for prefix in tag_prefixes(service):
        if tag.startswith(prefix):
            return tag[len(prefix) :]
    return ""


def tag_exists_for_version(service, version):
    for prefix in tag_prefixes(service):
        tag = f"{prefix}{version}"
        existing = run(["git", "rev-parse", "-q", "--verify", f"refs/tags/{tag}"], capture=True, check=False).strip()
        if existing:
            return tag
    return ""


def existing_tag_for_version(root, service, version):
    for prefix in tag_prefixes(service):
        tag = f"{prefix}{version}"
        existing = run(
            ["git", "rev-parse", "-q", "--verify", f"refs/tags/{tag}"],
            cwd=root,
            capture=True,
            check=False,
        ).strip()
        if existing:
            return tag
    return ""


def tag_sha(root, tag):
    return run(["git", "rev-list", "-n", "1", tag], cwd=root, capture=True).strip()


def service_tags_matching_suffix(service, suffix):
    tags = []
    for prefix in tag_prefixes(service):
        raw = run(["git", "tag", "-l", f"{prefix}{suffix}"], capture=True)
        tags.extend(line.strip() for line in raw.splitlines() if line.strip())
    return sorted(set(tags))


def existing_matching_tag_at_sha(root, service, suffix, sha):
    for tag in service_tags_matching_suffix(service, suffix):
        if tag_sha(root, tag) == sha:
            return tag
    return ""


def current_branch(root):
    if os.environ.get("GITHUB_REF_TYPE") == "branch" and os.environ.get("GITHUB_REF_NAME"):
        return os.environ["GITHUB_REF_NAME"]
    branch = run(["git", "rev-parse", "--abbrev-ref", "HEAD"], cwd=root, capture=True, check=False).strip()
    return "" if branch == "HEAD" else branch


def latest_service_tag_for_prefix(prefix):
    raw = run(["git", "tag", "-l", f"{prefix}*"], capture=True)
    candidates = []
    for line in raw.splitlines():
        tag = line.strip()
        if tag:
            candidates.append((tag[len(prefix) :], tag))
    if not candidates:
        return ""
    return sorted(candidates, key=lambda item: semverish_sort_key(item[0]))[-1][1]


def latest_service_tag(service):
    candidates = []
    for prefix in tag_prefixes(service):
        raw = run(["git", "tag", "-l", f"{prefix}*"], capture=True)
        for line in raw.splitlines():
            tag = line.strip()
            if tag:
                candidates.append((tag[len(prefix) :], tag))
    if not candidates:
        return ""
    return sorted(candidates, key=lambda item: semverish_sort_key(item[0]))[-1][1]


def synthesize_current_prefix_anchor(service):
    current_prefix = tag_prefix(service)
    legacy_prefix = (service.get("legacy_tag_prefix") or "").strip()
    if not legacy_prefix or legacy_prefix == current_prefix:
        return
    if latest_service_tag_for_prefix(current_prefix):
        return
    legacy_tag = latest_service_tag_for_prefix(legacy_prefix)
    if not legacy_tag:
        return
    version = legacy_tag[len(legacy_prefix) :]
    anchor = tag_for_version(service, version)
    if run(["git", "rev-parse", "-q", "--verify", f"refs/tags/{anchor}"], capture=True, check=False).strip():
        return
    sha = run(["git", "rev-list", "-n", "1", legacy_tag], capture=True).strip()
    run(["git", "tag", anchor, sha])
    print(f"[github-release] {service['id']}: synthesized local compatibility anchor {anchor} -> {legacy_tag} ({sha})")


def synthesize_initial_version_anchor(root, service):
    if latest_service_tag(service):
        return
    anchor = tag_for_version(service, INITIAL_RELEASE_FLOOR_VERSION)
    if run(["git", "rev-parse", "-q", "--verify", f"refs/tags/{anchor}"], cwd=root, capture=True, check=False).strip():
        return

    first_commits = run(["git", "rev-list", "--reverse", "HEAD", "--", service["path"]], cwd=root, capture=True).splitlines()
    if first_commits:
        sha = run(
            ["git", "rev-parse", "-q", "--verify", f"{first_commits[0]}^"],
            cwd=root,
            capture=True,
            check=False,
        ).strip() or first_commits[0]
    else:
        roots = run(["git", "rev-list", "--max-parents=0", "HEAD"], cwd=root, capture=True).splitlines()
        sha = roots[-1] if roots else ""

    if not sha:
        return
    run(["git", "tag", anchor, sha], cwd=root)
    print(
        f"[github-release] {service['id']}: synthesized local initial-version anchor "
        f"{anchor} ({sha}); missing version tags start at {INITIAL_RELEASE_VERSION}"
    )


def only_generated_changes(root, service, generated_paths):
    service_path = service["path"]
    last_tag = latest_service_tag(service)
    log_range = f"{last_tag}..HEAD" if last_tag else "HEAD"
    raw = run(
        ["git", "log", log_range, "--name-only", "--pretty=format:", "--", service_path],
        cwd=root,
        capture=True,
    )
    changed = sorted({line.strip() for line in raw.splitlines() if line.strip()})
    if not changed:
        print(
            f"[github-release] {service['id']}: no commits under {service_path} "
            f"since {last_tag or '<root>'}; skipping"
        )
        return True
    generated = set(generated_paths)
    real = [path for path in changed if Path(path).name not in generated]
    if real:
        return False
    print(
        f"[github-release] {service['id']}: only generated/mechanical files changed "
        f"under {service_path} since {last_tag or '<root>'}; skipping"
    )
    return True


def write_semantic_release_files(service_dir, service_name, release_tag_format, publish, draft):
    deps = {
        "semantic-release": "17.4.4",
        "semantic-release-monorepo": "^7.0.0",
    }
    plugins = [
        ["@semantic-release/commit-analyzer", {"releaseRules": RELEASE_RULES}],
        "@semantic-release/release-notes-generator",
    ]
    if publish:
        deps["@semantic-release/github"] = "7.2.3"
        plugins.append(["@semantic-release/github", {"draftRelease": draft}])

    package_json = {
        "name": service_name,
        "version": INITIAL_RELEASE_VERSION,
        "private": True,
        "devDependencies": deps,
    }
    release_config = {
        "extends": "semantic-release-monorepo",
        "tagFormat": release_tag_format,
        "branches": ["main"],
        "plugins": plugins,
    }
    (service_dir / "package.json").write_text(json.dumps(package_json, indent=2) + "\n")
    (service_dir / ".releaserc.json").write_text(json.dumps(release_config, indent=2) + "\n")


def install_semantic_release(service_dir):
    run(["npm", "install", "--package-lock=false"], cwd=service_dir)


def parse_next_version(output):
    match = re.search(r"next release version is\s+([^\s]+)", output, flags=re.IGNORECASE)
    return match.group(1) if match else ""


def no_release_output(output):
    return any(
        phrase in output
        for phrase in (
            "no relevant changes",
            "There are no commits",
            "is behind the remote",
        )
    )


def validate_version_file(root, service):
    service_dir = root / service["path"]
    version_file = service.get("version_file") or ""
    version_path = service_dir / version_file
    if not version_path.is_file():
        raise SystemExit(f"{service['id']}: version_file {version_file} not found")

    version = version_path.read_text().strip().lstrip("v")
    if not re.fullmatch(SEMVER_PATTERN, version):
        raise SystemExit(f"{service['id']}: {version_file} does not contain a supported SemVer: {version}")

    source_file = service.get("version_major_minor_source_file") or ""
    if source_file:
        source_path = service_dir / source_file
        if not source_path.is_file():
            raise SystemExit(f"{service['id']}: version_major_minor_source_file {source_file} not found")
        source = re.search(r"v?(\d+\.\d+\.\d+)", source_path.read_text())
        if not source:
            raise SystemExit(f"{service['id']}: no semantic version found in {source_file}")
        if ".".join(source.group(1).split(".")[:2]) != ".".join(version.split("-")[0].split(".")[:2]):
            raise SystemExit(
                f"{service['id']}: {version_file}={version} does not match "
                f"{source_file} major/minor {source.group(1)}"
            )
    return version


def create_release(tag, title, notes, draft, dry_run):
    if dry_run:
        print(f"[github-release] dry-run: would create GitHub release {tag}")
        print(notes)
        return
    view = subprocess.run(["gh", "release", "view", tag], text=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    if view.returncode == 0:
        print(f"[github-release] GitHub release {tag} already exists; leaving it unchanged")
        return
    cmd = ["gh", "release", "create", tag, "--verify-tag", "--title", title, "--notes", notes]
    if draft:
        cmd.append("--draft")
    run(cmd)


def publish_tag_for_version(root, service, version, dry_run, draft, reason):
    tag = tag_for_version(service, version)
    head = run(["git", "rev-parse", "--verify", "HEAD^{commit}"], cwd=root, capture=True).strip()
    current = run(["git", "rev-parse", "-q", "--verify", f"refs/tags/{tag}"], cwd=root, capture=True, check=False).strip()
    if current:
        existing_sha = tag_sha(root, tag)
        if existing_sha == head:
            print(f"[github-release] {service['id']}: {tag} already points at HEAD; skipping")
            return
        raise SystemExit(f"{service['id']}: {tag} already exists at {existing_sha}, not {head}")
    for prefix in tag_prefixes(service):
        existing = f"{prefix}{version}"
        if existing == tag:
            continue
        if run(["git", "rev-parse", "-q", "--verify", f"refs/tags/{existing}"], cwd=root, capture=True, check=False).strip():
            existing_sha = tag_sha(root, existing)
            if existing_sha != head:
                raise SystemExit(f"{service['id']}: {existing} already exists at {existing_sha}, not {head}")
            print(f"[github-release] {service['id']}: legacy anchor {existing} points at HEAD; creating current tag {tag}")
    notes = f"Release {tag}\n\nPackage version: {version}\nSource: {reason}"
    if dry_run:
        print(f"[github-release] {service['id']}: would create {tag} at HEAD")
        print(notes)
        return
    run(["git", "tag", tag, "HEAD"], cwd=root)
    run(["git", "push", "origin", f"refs/tags/{tag}"], cwd=root)
    create_release(tag, tag, notes, draft, dry_run=False)


def publish_version_file_release(root, service, dry_run, draft):
    version = validate_version_file(root, service)
    existing = existing_tag_for_version(root, service, version)
    if existing:
        existing_sha = tag_sha(root, existing)
        print(f"[github-release] {service['id']}: {existing} already exists at {existing_sha}; skipping")
        return
    publish_tag_for_version(root, service, version, dry_run, draft, f"{service.get('version_file') or 'version file'}")


def publish_dev_prerelease(root, service, dry_run, draft):
    base_version = validate_version_file(root, service)
    if "-" in base_version:
        raise SystemExit(f"{service['id']}: dev_prerelease version_file must contain a stable X.Y.Z base, got {base_version}")

    branch = current_branch(root)
    default_branch = os.environ.get("GITHUB_DEFAULT_BRANCH", "main")
    head = run(["git", "rev-parse", "--verify", "HEAD^{commit}"], cwd=root, capture=True).strip()
    if branch == default_branch:
        existing_at_head = existing_matching_tag_at_sha(root, service, f"{base_version}-dev.*", head)
        if existing_at_head:
            print(f"[github-release] {service['id']}: {existing_at_head} already points at HEAD; skipping")
            return
        last_dev = -1
        pattern = re.compile(rf"^{re.escape(base_version)}-dev\.(\d+)$")
        for tag in service_tags_matching_suffix(service, f"{base_version}-dev.*"):
            match = pattern.fullmatch(version_from_tag(service, tag))
            if match:
                last_dev = max(last_dev, int(match.group(1)))
        version = f"{base_version}-dev.{last_dev + 1}"
        publish_tag_for_version(root, service, version, dry_run, draft, f"{service.get('version_file') or 'version file'} dev prerelease")
        return

    branch_prefix = f"release-{tag_prefix(service)}"
    if branch.startswith(branch_prefix):
        train = branch[len(branch_prefix) :]
        if not re.fullmatch(r"(?:0|[1-9]\d*)\.(?:0|[1-9]\d*)", train):
            raise SystemExit(f"{service['id']}: release branch {branch} must end with X.Y")
        if ".".join(base_version.split(".")[:2]) != train:
            raise SystemExit(f"{service['id']}: {service.get('version_file')}={base_version} does not match release branch train {train}")

        existing_at_head = existing_matching_tag_at_sha(root, service, f"{train}.*", head)
        if existing_at_head and "-" not in version_from_tag(service, existing_at_head):
            print(f"[github-release] {service['id']}: {existing_at_head} already points at HEAD; skipping")
            return
        last_patch = -1
        pattern = re.compile(rf"^{re.escape(train)}\.(\d+)$")
        for tag in service_tags_matching_suffix(service, f"{train}.*"):
            match = pattern.fullmatch(version_from_tag(service, tag))
            if match:
                last_patch = max(last_patch, int(match.group(1)))
        version = base_version if last_patch < 0 else f"{train}.{last_patch + 1}"
        publish_tag_for_version(root, service, version, dry_run, draft, f"{service.get('version_file') or 'version file'} release branch")
        return

    print(f"[github-release] {service['id']}: dev prerelease tags only publish on {default_branch} or release branches; branch={branch or '<detached>'}; skipping")


def auto_release(args):
    root = repo_root()
    metadata = load_metadata(root, args.metadata)
    auto_tagging_enabled, dry_run = github_release_mode()
    draft = bool_env("NVCF_GITHUB_RELEASE_DRAFT", False)
    service_filter = args.service or os.environ.get("NVCF_GITHUB_RELEASE_SERVICE", "")
    generated_paths = metadata.get("release_generated_paths", [])

    print(
        f"[github-release] mode={'dry-run' if dry_run else 'publish'} "
        f"auto_tagging_enabled={str(auto_tagging_enabled).lower()} "
        f"draft={str(draft).lower()} service_filter={service_filter or '<all>'}"
    )

    for service in metadata.get("services", []):
        if service_filter and service_filter not in {service["id"], service["service_name"]}:
            continue
        service_dir = root / service["path"]
        if not service_dir.is_dir():
            print(f"[github-release] {service['id']}: {service['path']} is not present in this checkout; skipping")
            continue

        print(f"::group::github-release {service['id']}")
        try:
            if service.get("dev_prerelease"):
                publish_dev_prerelease(root, service, dry_run=dry_run, draft=draft)
                continue

            if service.get("version_file"):
                publish_version_file_release(root, service, dry_run=dry_run, draft=draft)
                continue

            if only_generated_changes(root, service, generated_paths):
                continue
            synthesize_current_prefix_anchor(service)
            synthesize_initial_version_anchor(root, service)

            write_semantic_release_files(
                service_dir,
                service["service_name"],
                tag_format(service),
                publish=not dry_run,
                draft=draft,
            )
            install_semantic_release(service_dir)

            if dry_run:
                code, output = stream(["npx", "semantic-release", "--dry-run", "--no-ci", "--debug"], cwd=service_dir)
                next_version = parse_next_version(output)
                if next_version:
                    print(f"[github-release] {service['id']}: would create {tag_for_version(service, next_version)}")
                elif code == 0 and no_release_output(output):
                    print(f"[github-release] {service['id']}: no release-worthy commits")
                else:
                    raise SystemExit(f"{service['id']}: semantic-release dry-run produced no NEXT_VERSION")
            else:
                run(["npx", "semantic-release", "--no-ci"], cwd=service_dir)
        finally:
            print("::endgroup::")


def parse_release_tag(tag, metadata):
    path_match = re.fullmatch(rf"(?P<package>[A-Za-z0-9._/-]+)/v(?P<version>{SEMVER_PATTERN})", tag)
    if path_match and not path_match.group("package").startswith("/"):
        return {
            "kind": "path",
            "package": path_match.group("package"),
            "version": path_match.group("version"),
        }

    for service in metadata.get("services", []):
        for prefix in tag_prefixes(service):
            if not tag.startswith(prefix):
                continue
            version = tag[len(prefix) :]
            if re.fullmatch(SEMVER_PATTERN, version):
                return {
                    "kind": "service",
                    "package": service["service_name"],
                    "version": version,
                }
    return {}


def release_branch(parsed):
    major_minor = ".".join(parsed["version"].split("-")[0].split(".")[:2])
    if parsed["kind"] == "path":
        return f"release-{parsed['package']}/v{major_minor}"
    return f"release-{parsed['package']}-v{major_minor}"


def tag_release(args):
    root = repo_root()
    metadata = load_metadata(root, args.metadata)
    tag = args.tag or os.environ.get("GITHUB_REF_NAME", "")
    if not tag:
        raise SystemExit("tag mode requires a tag argument or GITHUB_REF_NAME")

    auto_tagging_enabled, dry_run = github_release_mode()
    draft = bool_env("NVCF_GITHUB_RELEASE_DRAFT", False)
    parsed = parse_release_tag(tag, metadata)
    if not parsed:
        print(f"[github-release] {tag} is not a supported release tag; skipping")
        return

    branch = release_branch(parsed)
    notes = "\n".join(
        [
            f"Release {tag}",
            "",
            f"Package: {parsed['package']}",
            f"Version: {parsed['version']}",
            f"Release branch: {branch}",
        ]
    )
    print(
        f"[github-release] valid {parsed['kind']} release tag: tag={tag} "
        f"version={parsed['version']} release_branch={branch} "
        f"auto_tagging_enabled={str(auto_tagging_enabled).lower()}"
    )
    create_release(tag, tag, notes, draft=draft, dry_run=dry_run)


def fetch_semantic_release_notes(root):
    refspec = "+refs/notes/semantic-release:refs/notes/semantic-release"
    result = subprocess.run(
        ["git", "fetch", "origin", refspec],
        cwd=root,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        check=False,
    )
    output = result.stdout or ""
    if result.returncode == 0:
        return
    if "couldn't find remote ref refs/notes/semantic-release" in output:
        print("[github-release] origin has no refs/notes/semantic-release yet; starting a new notes ref")
        return
    sys.stdout.write(output)
    raise SystemExit("failed to fetch refs/notes/semantic-release; rerun with --no-fetch-notes only if the local notes ref is known current")


def existing_semantic_release_note(root, sha):
    result = subprocess.run(
        ["git", "notes", "--ref=refs/notes/semantic-release", "show", sha],
        cwd=root,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        check=False,
    )
    if result.returncode == 0:
        return result.stdout
    return ""


def semantic_release_note_git_tag(note_text, sha):
    try:
        note = json.loads(note_text)
    except json.JSONDecodeError as exc:
        raise SystemExit(f"refs/notes/semantic-release note on {sha} is not valid JSON: {exc}") from exc
    if not isinstance(note, dict):
        raise SystemExit(f"refs/notes/semantic-release note on {sha} must be a JSON object")
    git_tag = note.get("gitTag")
    if not isinstance(git_tag, str) or not git_tag:
        raise SystemExit(f"refs/notes/semantic-release note on {sha} does not contain a gitTag string")
    return git_tag


def anchor_release(args):
    root = repo_root()
    metadata = load_metadata(root, args.metadata)
    service = find_service(metadata, args.service)
    version = args.version.strip().lstrip("v")
    if not re.fullmatch(SEMVER_PATTERN, version):
        raise SystemExit(f"{args.service}: unsupported SemVer {args.version!r}")

    tag = tag_for_version(service, version)
    sha = run(["git", "rev-parse", "--verify", f"{args.ref}^{{commit}}"], cwd=root, capture=True).strip()

    if not args.no_fetch_notes and not args.dry_run:
        fetch_semantic_release_notes(root)

    existing = run(["git", "rev-parse", "-q", "--verify", f"refs/tags/{tag}"], cwd=root, capture=True, check=False).strip()
    if existing:
        existing_sha = run(["git", "rev-list", "-n", "1", tag], cwd=root, capture=True).strip()
        if existing_sha != sha:
            raise SystemExit(f"{tag} already exists at {existing_sha}, not {sha}")
        print(f"[github-release] {tag} already points at {sha}")
    elif args.dry_run:
        print(f"[github-release] dry-run: would create tag {tag} at {sha}")
    else:
        run(["git", "tag", tag, sha], cwd=root)
        print(f"[github-release] created tag {tag} at {sha}")

    note = {
        "channels": [None],
        "name": f"v{version}",
        "gitHead": sha,
        "gitTag": tag,
    }
    existing_note = existing_semantic_release_note(root, sha)
    if existing_note:
        existing_note_tag = semantic_release_note_git_tag(existing_note, sha)
        if existing_note_tag == tag:
            print(f"[github-release] refs/notes/semantic-release already contains {tag} on {sha}")
        else:
            raise SystemExit(
                f"refs/notes/semantic-release already has gitTag {existing_note_tag} on {sha}; "
                "merge the new anchor JSON manually instead of overwriting it"
            )
    elif args.dry_run:
        print(f"[github-release] dry-run: would add semantic-release note to {sha}: {json.dumps(note, sort_keys=True)}")
    else:
        run(
            ["git", "notes", "--ref=refs/notes/semantic-release", "add", "-m", json.dumps(note, sort_keys=True), sha],
            cwd=root,
        )
        print(f"[github-release] added semantic-release note for {tag} on {sha}")

    if args.push:
        if args.dry_run:
            print(f"[github-release] dry-run: would push refs/tags/{tag} and refs/notes/semantic-release")
        else:
            run(["git", "push", "origin", f"refs/tags/{tag}"], cwd=root)
            run(["git", "push", "origin", "refs/notes/semantic-release"], cwd=root)
            print(f"[github-release] pushed {tag} and refs/notes/semantic-release")


def main():
    parser = argparse.ArgumentParser(description="GitHub release automation for NVCF")
    parser.add_argument(
        "--metadata",
        default=os.environ.get("NVCF_GITHUB_RELEASE_METADATA", "tools/ci/github-release-subprojects.json"),
        help="path to generated GitHub release metadata",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    auto = subparsers.add_parser("auto", help="compute or publish service release tags")
    auto.add_argument("--service", default="", help="optional service id or service_name filter")
    auto.set_defaults(func=auto_release)

    tag = subparsers.add_parser("tag", help="validate a pushed tag and create release notes")
    tag.add_argument("tag", nargs="?", help="tag name, defaults to GITHUB_REF_NAME")
    tag.set_defaults(func=tag_release)

    anchor = subparsers.add_parser("anchor", help="create a GitHub cutover tag and semantic-release note")
    anchor.add_argument("--service", required=True, help="service id, service_name, or path from release metadata")
    anchor.add_argument("--version", required=True, help="released SemVer to anchor, with or without leading v")
    anchor.add_argument("--ref", default="HEAD", help="GitHub commit/ref to anchor, defaults to HEAD")
    anchor.add_argument("--push", action="store_true", help="push the tag and refs/notes/semantic-release to origin")
    anchor.add_argument("--dry-run", action="store_true", help="show the tag/note that would be created")
    anchor.add_argument("--no-fetch-notes", action="store_true", help="do not fetch refs/notes/semantic-release before adding a note")
    anchor.set_defaults(func=anchor_release)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
