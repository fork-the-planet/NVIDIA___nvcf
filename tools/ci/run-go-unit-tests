set -euo pipefail

usage() {
    cat <<'EOF'
Usage: ./tools/ci/run-go-unit-tests <module-dir> [--results-dir <path>] [--coverage-threshold <percent>]

Run `go test` with race detection and coverage for a Go module, write JSON and
coverage artifacts, and fail if coverage falls below the configured threshold.
EOF
}

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
module_dir="${1:-}"
shift || true

if [[ "${module_dir}" == "-h" || "${module_dir}" == "--help" ]]; then
    usage
    exit 0
fi

if [[ -z "${module_dir}" ]]; then
    usage >&2
    exit 1
fi

if [[ "${module_dir}" != /* ]]; then
    module_dir="${repo_root}/${module_dir}"
fi

if [[ ! -f "${module_dir}/go.mod" ]]; then
    echo "missing go.mod under ${module_dir}" >&2
    exit 1
fi

results_dir=""
coverage_threshold=""
coverage_threshold_explicit=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --results-dir)
            [[ $# -ge 2 ]] || {
                echo "missing value for --results-dir" >&2
                exit 1
            }
            results_dir="$2"
            shift 2
            ;;
        --coverage-threshold)
            [[ $# -ge 2 ]] || {
                echo "missing value for --coverage-threshold" >&2
                exit 1
            }
            coverage_threshold="$2"
            coverage_threshold_explicit=true
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "unexpected argument: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
done

if [[ -z "${results_dir}" ]]; then
    results_dir="public/$(basename "${module_dir}")"
fi

if [[ "${results_dir}" != /* ]]; then
    results_dir="${repo_root}/${results_dir}"
fi

cd "${module_dir}"

if [[ -f .env ]]; then
    set -a
    # shellcheck disable=SC1091
    source .env
    set +a
    if [[ "${coverage_threshold_explicit}" != true ]]; then
        coverage_threshold="${EGX_GO_TEST_COVERAGE_THRESHOLD:-85}"
    fi
fi

if [[ -z "${coverage_threshold}" ]]; then
    coverage_threshold="${EGX_GO_TEST_COVERAGE_THRESHOLD:-85}"
fi

mkdir -p "${results_dir}"

# `go list`/`go test -mod=vendor` are module-scoped. When CI enables a root
# `go.work`, keep these commands in module mode so they continue to use the
# module's tracked vendor tree instead of requiring a workspace-level vendor/.
mapfile -t packages < <(GOWORK=off GOFLAGS=-mod=vendor go list ./...)

set +e
GOWORK=off GOFLAGS=-mod=vendor go test -json -race \
    -coverprofile="${results_dir}/cover.txt" \
    -covermode=atomic \
    -timeout 10m \
    "${packages[@]}" | tee "${results_dir}/report.json"
test_exit=${PIPESTATUS[0]}
set -e

if [[ ! -f "${results_dir}/cover.txt" ]]; then
    echo "FAIL: coverage profile was not generated." >&2
    exit "${test_exit:-1}"
fi

# Filter paths that should not contribute to the coverage number:
#   - zz_generated:   autogenerated files
#   - /cmd/:          binary entrypoints
#   - /examples/:     sample code shipped alongside the module
#   - /test/mocks/:   test doubles used by other packages' tests
# A module can extend this list by setting EGX_GO_TEST_COVERAGE_EXCLUDE_REGEX
# in its .env (a regex fragment joined with OR, e.g. "/jwe-utils/cli/").
exclude_regex='zz_generated|/cmd/|/examples/|/test/mocks/'
if [[ -n "${EGX_GO_TEST_COVERAGE_EXCLUDE_REGEX:-}" ]]; then
    exclude_regex="${exclude_regex}|${EGX_GO_TEST_COVERAGE_EXCLUDE_REGEX}"
fi
grep -vE "${exclude_regex}" "${results_dir}/cover.txt" > "${results_dir}/cover_filtered.txt"
mv "${results_dir}/cover_filtered.txt" "${results_dir}/cover.txt"

go tool cover -html="${results_dir}/cover.txt" -o "${results_dir}/cover.html"
coverage_report="$(go tool cover -func="${results_dir}/cover.txt")"
printf '%s\n' "${coverage_report}"

if [[ "${test_exit}" -ne 0 ]]; then
    exit "${test_exit}"
fi

coverage_value="$(printf '%s\n' "${coverage_report}" | awk '/^total:/{gsub("%", "", $3); print $3}')"
if [[ -z "${coverage_value}" ]]; then
    echo "FAIL: could not determine total coverage." >&2
    exit 1
fi

coverage_int="${coverage_value%.*}"
echo "Test coverage threshold: ${coverage_threshold}"
echo "Actual average coverage: ${coverage_value}"
if [[ "${coverage_int}" -lt "${coverage_threshold}" ]]; then
    echo "FAIL: actual test coverage is BELOW threshold." >&2
    exit 1
fi

echo "PASS: actual test coverage meets threshold."
