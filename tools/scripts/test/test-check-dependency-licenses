set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CHECKER="${SCRIPT_DIR}/../../ci/check-dependency-licenses"

TEMP_DIRS=()

cleanup() {
    local path
    for path in "${TEMP_DIRS[@]}"; do
        rm -rf "${path}"
    done
}

make_tempdir() {
    local tmpdir
    tmpdir="$(mktemp -d)"
    TEMP_DIRS+=("${tmpdir}")
    echo "${tmpdir}"
}

trap cleanup EXIT

REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
ALLOWLIST_FILE="${REPO_ROOT}/.allowed-licenses.txt"

assert_equals() {
    local expected="$1"
    local actual="$2"
    local message="$3"

    if [[ "${actual}" != "${expected}" ]]; then
        echo "FAIL: ${message}" >&2
        echo "expected: ${expected}" >&2
        echo "actual:   ${actual}" >&2
        exit 1
    fi
}

assert_contains() {
    local needle="$1"
    local haystack="$2"
    local message="$3"

    if [[ "${haystack}" != *"${needle}"* ]]; then
        echo "FAIL: ${message}" >&2
        echo "missing: ${needle}" >&2
        exit 1
    fi
}

assert_file_exists() {
    local path="$1"
    local message="$2"

    if [[ ! -f "${path}" ]]; then
        echo "FAIL: ${message}" >&2
        echo "missing file: ${path}" >&2
        exit 1
    fi
}

assert_file_not_exists() {
    local path="$1"
    local message="$2"

    if [[ -e "${path}" ]]; then
        echo "FAIL: ${message}" >&2
        echo "unexpected path: ${path}" >&2
        exit 1
    fi
}

test_baseline_paths_live_under_tools_directory() {
    local repo_root
    repo_root="$(make_tempdir)"
    mkdir -p "${repo_root}/src/control-plane-services/nvcf-function-deployment-stages/common"

    local actual
    actual="$(
        REPO_ROOT="${repo_root}" bash -c '
            # shellcheck source=/dev/null
            source "$1"
            baseline_file_for_module "$2"
        ' bash "${CHECKER}" "${repo_root}/src/control-plane-services/nvcf-function-deployment-stages/common"
    )"

    assert_equals \
        "${repo_root}/tools/check-dependency-licenses-baselines/src/control-plane-services/nvcf-function-deployment-stages/common/.license-baseline.txt" \
        "${actual}" \
        "baseline path should be rooted under tools"
}

test_update_baseline_writes_outside_the_module_tree() {
    local repo_root
    repo_root="$(make_tempdir)"
    local module_dir="${repo_root}/src/control-plane-services/nvcf-function-deployment-stages/common"
    local central_baseline="${repo_root}/tools/check-dependency-licenses-baselines/src/control-plane-services/nvcf-function-deployment-stages/common/.license-baseline.txt"
    mkdir -p "${module_dir}"

    local output
    output="$(
        REPO_ROOT="${repo_root}" bash -c '
            # shellcheck source=/dev/null
            source "$1"
            UPDATE_BASELINE=true
            ratchet_module "$2" "[NO LICENSE] example.com/lib"
        ' bash "${CHECKER}" "${module_dir}"
    )"

    assert_contains \
        "tools/check-dependency-licenses-baselines/src/control-plane-services/nvcf-function-deployment-stages/common/.license-baseline.txt" \
        "${output}" \
        "update output should report the central baseline path"
    assert_file_exists "${central_baseline}" "baseline should be written under tools"
    assert_file_not_exists "${module_dir}/.license-baseline.txt" "baseline should not be written inside the module"

    local rendered
    rendered="$(<"${central_baseline}")"
    assert_contains "[NO LICENSE] example.com/lib" "${rendered}" "baseline file should include the recorded violation"
}

test_existing_central_baseline_is_used_for_resolved_entries() {
    local repo_root
    repo_root="$(make_tempdir)"
    local module_dir="${repo_root}/src/compute-plane-services/nvca"
    local central_dir="${repo_root}/tools/check-dependency-licenses-baselines/src/compute-plane-services/nvca"
    local central_baseline="${central_dir}/.license-baseline.txt"
    mkdir -p "${module_dir}" "${central_dir}"
    cat > "${central_baseline}" <<'EOF'
# Known license check failures — ratchet baseline.
# Auto-generated by: ./tools/ci/check-dependency-licenses --update-baseline
# New dependencies must NOT add entries to this file.
# Remove entries as they are fixed (LICENSE files added or deps replaced).
[NO LICENSE] example.com/legacy
EOF

    local output
    output="$(
        REPO_ROOT="${repo_root}" bash -c '
            # shellcheck source=/dev/null
            source "$1"
            ratchet_module "$2" ""
        ' bash "${CHECKER}" "${module_dir}"
    )"

    assert_contains \
        "Resolved (remove from tools/check-dependency-licenses-baselines/src/compute-plane-services/nvca/.license-baseline.txt):" \
        "${output}" \
        "resolved output should point at the central baseline"
    assert_contains "[NO LICENSE] example.com/legacy" "${output}" "resolved output should include the baseline entry"
}

test_repo_allowlist_accepts_mpl_2_0() {
    assert_file_exists "${ALLOWLIST_FILE}" "shared allowlist should exist"

    local allowlist
    allowlist="$(<"${ALLOWLIST_FILE}")"
    assert_contains $'\nMPL-2.0\n' $'\n'"${allowlist}"$'\n' "shared allowlist should accept MPL-2.0"
}

main() {
    test_baseline_paths_live_under_tools_directory
    test_update_baseline_writes_outside_the_module_tree
    test_existing_central_baseline_is_used_for_resolved_entries
    test_repo_allowlist_accepts_mpl_2_0
    echo "PASS: test-check-dependency-licenses"
}

main "$@"
