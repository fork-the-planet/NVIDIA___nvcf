set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/../../.." && pwd)"
checker="${repo_root}/tools/ci/check-go-vendor"

workdir="$(mktemp -d)"
trap 'rm -rf "${workdir}"' EXIT

module_dir="${workdir}/example"
mkdir -p "${module_dir}"

cat > "${module_dir}/go.mod" <<'EOF'
module example.com/test

go 1.24.0
EOF

cat > "${module_dir}/main.go" <<'EOF'
package main

func main() {}
EOF

git -C "${workdir}" init -q
git -C "${workdir}" config user.name "Test User"
git -C "${workdir}" config user.email "test@example.com"
(
    cd "${module_dir}"
    GOWORK=off go mod vendor
)
git -C "${workdir}" add example/go.mod example/main.go
git -C "${workdir}" add example/vendor 2>/dev/null || true
git -C "${workdir}" commit -q -m "initial module"

cat > "${workdir}/go.work" <<'EOF'
go 1.24.0

use ./example
EOF

if ! output="$(GOWORK="${workdir}/go.work" "${checker}" "${module_dir}" 2>&1)"; then
    echo "expected vendor check to succeed with workspace mode enabled for the job" >&2
    echo "${output}" >&2
    exit 1
fi

echo "PASS: test-check-go-vendor"
