set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CHECK_LICENSE_HEADERS="${SCRIPT_DIR}/../../ci/check-license-headers"

TEMP_DIRS=()
TEMP_FILES=()
RUN_STATUS=0
RUN_STDOUT=""
RUN_STDERR=""

GO_HEADER='// SPDX-FileCopyrightText: Copyright (c) NVIDIA CORPORATION & AFFILIATES. All rights reserved.
// SPDX-License-Identifier: Apache-2.0
//
// Licensed under the Apache License, Version 2.0 (the "License");
'

