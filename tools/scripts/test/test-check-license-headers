// SPDX-License-Identifier: MPL-2.0
'

cleanup() {
    local path

    for path in "${TEMP_DIRS[@]}"; do
        rm -rf "${path}"
    done

    for path in "${TEMP_FILES[@]}"; do
        rm -f "${path}"
    done
}

make_tempdir() {
    local tmpdir

    tmpdir="$(mktemp -d)"
    TEMP_DIRS+=("${tmpdir}")
    echo "${tmpdir}"
}

make_tempfile() {
    local tmpfile

    tmpfile="$(mktemp)"
    TEMP_FILES+=("${tmpfile}")
    echo "${tmpfile}"
}

trap cleanup EXIT

assert_equals() {
    local expected="$1"
    local actual="$2"
    local message="$3"

    if [[ "${actual}" != "${expected}" ]]; then
        echo "FAIL: ${message}" >&2
        echo "expected: ${expected}" >&2
        echo "actual:   ${actual}" >&2
        exit 1
    fi
}

assert_contains() {
    local needle="$1"
    local haystack="$2"
    local message="$3"

    if [[ "${haystack}" != *"${needle}"* ]]; then
        echo "FAIL: ${message}" >&2
        echo "missing: ${needle}" >&2
        exit 1
    fi
}

assert_not_contains() {
    local needle="$1"
    local haystack="$2"
    local message="$3"

    if [[ "${haystack}" == *"${needle}"* ]]; then
        echo "FAIL: ${message}" >&2
        echo "unexpected: ${needle}" >&2
        exit 1
    fi
}

assert_status() {
    local expected="$1"
    local actual="$2"
    local message="$3"

    if [[ "${actual}" -ne "${expected}" ]]; then
        echo "FAIL: ${message}" >&2
        echo "expected status: ${expected}" >&2
        echo "actual status:   ${actual}" >&2
        exit 1
    fi
}

assert_order() {
    local first="$1"
    local second="$2"
    local haystack="$3"
    local message="$4"
    local after_first

    after_first="${haystack#*"${first}"}"
    if [[ "${after_first}" == "${haystack}" || "${after_first}" != *"${second}"* ]]; then
        echo "FAIL: ${message}" >&2
        echo "expected order: ${first} before ${second}" >&2
        exit 1
    fi
}

write_file() {
    local path="$1"
    local content="$2"

    mkdir -p "$(dirname "${path}")"
    printf '%s' "${content}" > "${path}"
}

run_checker() {
    local repo_root="$1"
    shift

    local stdout_file stderr_file
    stdout_file="$(make_tempfile)"
    stderr_file="$(make_tempfile)"

    set +e
    REPO_ROOT="${repo_root}" "${CHECK_LICENSE_HEADERS}" "$@" >"${stdout_file}" 2>"${stderr_file}"
    RUN_STATUS=$?
    set -e

    RUN_STDOUT="$(<"${stdout_file}")"
    RUN_STDERR="$(<"${stderr_file}")"
}

test_groups_failures_by_import_path_and_top_level_dir() {
    local repo_root
    repo_root="$(make_tempdir)"

    write_file "${repo_root}/imports.yaml" 'imports:
  - path: src/service-a
    repo: https://example.com/service-a.git
'
    write_file "${repo_root}/.oss-allowlist" 'src/service-a/**
tools/**
'
    write_file "${repo_root}/src/service-a/main.go" 'package main
'
    write_file "${repo_root}/tools/helper.py" "print('hi')"$'\n'

    run_checker "${repo_root}"

    assert_status 1 "${RUN_STATUS}" "missing headers should fail"
    assert_contains "ERROR: missing or invalid Apache 2.0 license headers in 2 files across 2 repo/path groups." "${RUN_STDERR}" "summary should count failures and groups"
    assert_contains "Checked 2 files." "${RUN_STDERR}" "summary should report checked files"
    assert_contains "[src/service-a] https://example.com/service-a.git" "${RUN_STDERR}" "import path section should include repo URL"
    assert_contains "  1 files missing headers (go=1)" "${RUN_STDERR}" "Go failure should be counted"
    assert_contains "  - src/service-a/main.go" "${RUN_STDERR}" "Go failure path should be listed"
    assert_contains "[tools]" "${RUN_STDERR}" "top-level tools section should be present"
    assert_contains "  1 files missing headers (python=1)" "${RUN_STDERR}" "Python failure should be counted"
    assert_contains "  - tools/helper.py" "${RUN_STDERR}" "Python failure path should be listed"
}

test_lists_only_repo_groups_when_requested() {
    local repo_root
    repo_root="$(make_tempdir)"

    write_file "${repo_root}/imports.yaml" 'imports:
  - path: src/service-a
    repo: https://example.com/service-a.git
'
    write_file "${repo_root}/.oss-allowlist" 'src/service-a/**
tools/**
'
    write_file "${repo_root}/src/service-a/main.go" 'package main
'
    write_file "${repo_root}/tools/helper.py" "print('hi')"$'\n'

    run_checker "${repo_root}" --list-repos-only

    assert_status 1 "${RUN_STATUS}" "missing headers should still fail in repo-only mode"
    assert_contains "ERROR: missing or invalid Apache 2.0 license headers in 2 files across 2 repo/path groups." "${RUN_STDERR}" "summary should still count failures and groups"
    assert_contains "[src/service-a] https://example.com/service-a.git" "${RUN_STDERR}" "import path should still be listed"
    assert_contains "[tools]" "${RUN_STDERR}" "top-level dir should still be listed"
    assert_not_contains "files missing headers" "${RUN_STDERR}" "repo-only mode should omit per-group counts"
    assert_not_contains "  - src/service-a/main.go" "${RUN_STDERR}" "repo-only mode should omit file paths"
    assert_not_contains "  - tools/helper.py" "${RUN_STDERR}" "repo-only mode should omit file paths"
}

test_skips_vendor_go_files_and_detects_helm_files_under_chart_roots() {
    local repo_root
    repo_root="$(make_tempdir)"

    write_file "${repo_root}/imports.yaml" 'imports:
  - path: deploy/app-chart
    repo: https://example.com/app-chart.git
'
    write_file "${repo_root}/.oss-allowlist" 'deploy/app-chart/**
'
    write_file "${repo_root}/deploy/app-chart/Chart.yaml" "${HELM_HEADER}apiVersion: v2"$'\n'
    write_file "${repo_root}/deploy/app-chart/templates/deployment.yaml" 'kind: Deployment
'
    write_file "${repo_root}/deploy/app-chart/vendor/example/lib.go" 'package example
'

    run_checker "${repo_root}"

    assert_status 1 "${RUN_STATUS}" "missing Helm header should fail"
    assert_contains "Checked 2 files." "${RUN_STDERR}" "vendor Go file should be skipped"
    assert_contains "  1 files missing headers (helm=1)" "${RUN_STDERR}" "Helm failure should be counted"
    assert_contains "  - deploy/app-chart/templates/deployment.yaml" "${RUN_STDERR}" "template file should be reported"
    assert_not_contains "vendor/example/lib.go" "${RUN_STDERR}" "vendor Go file should not be reported"
}

test_accepts_valid_headers() {
    local repo_root
    repo_root="$(make_tempdir)"

    write_file "${repo_root}/imports.yaml" 'imports:
'
    write_file "${repo_root}/.oss-allowlist" 'tools/**
'
    write_file "${repo_root}/tools/helper.py" "${PYTHON_HEADER}print('ok')"$'\n'

    run_checker "${repo_root}"

    assert_status 0 "${RUN_STATUS}" "valid headers should pass"
    assert_equals "All checked files have Apache 2.0 SPDX headers (1 files checked)." "${RUN_STDOUT}" "success message should match"
    assert_equals "" "${RUN_STDERR}" "success should not write to stderr"
}

test_accepts_allowlisted_spdx_headers_only_in_matching_dir() {
    local repo_root
    repo_root="$(make_tempdir)"

    write_file "${repo_root}/imports.yaml" 'imports:
'
    write_file "${repo_root}/.oss-allowlist" 'src/compute-plane-services/ess-agent/**
tools/**
'
    write_file "${repo_root}/src/compute-plane-services/ess-agent/main.go" "${MPL_HEADER}package main"$'\n'
    write_file "${repo_root}/tools/helper.go" "${MPL_HEADER}package helper"$'\n'

    run_checker "${repo_root}" --allow-spdx-dir "src/compute-plane-services/ess-agent:MPL-2.0"

    assert_status 1 "${RUN_STATUS}" "non-allowlisted MPL header should still fail"
    assert_contains "ERROR: missing or invalid required license headers in 1 files across 1 repo/path groups." "${RUN_STDERR}" "summary should switch to generic wording when alternate SPDX ids are allowed"
    assert_contains "Checked 2 files." "${RUN_STDERR}" "both files should still be counted as checked"
    assert_contains "  - tools/helper.go" "${RUN_STDERR}" "file outside allowlisted dir should still be reported"
    assert_not_contains "src/compute-plane-services/ess-agent/main.go" "${RUN_STDERR}" "file inside allowlisted dir should pass"
}

