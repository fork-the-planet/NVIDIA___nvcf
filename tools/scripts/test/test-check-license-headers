test_nested_oss_allowlists_are_relative_to_their_directory() {
    local repo_root
    repo_root="$(make_tempdir)"

    write_file "${repo_root}/imports.yaml" 'imports:
  - path: src/service-a
    repo: https://example.com/service-a.git
'
    write_file "${repo_root}/src/service-a/.oss-allowlist" 'main.go
cmd/**
'
    write_file "${repo_root}/src/service-a/main.go" "${GO_HEADER}package main"$'\n'
    write_file "${repo_root}/src/service-a/cmd/server/main.go" 'package main
'
    write_file "${repo_root}/src/service-a/internal/private.go" 'package internal
'

    run_checker "${repo_root}"

    assert_status 1 "${RUN_STATUS}" "nested allowlisted file missing a header should fail"
    assert_contains "Checked 2 files." "${RUN_STDERR}" "nested allowlist should include only its matched files"
    assert_contains "  - src/service-a/cmd/server/main.go" "${RUN_STDERR}" "nested allowlisted file should be reported"
    assert_not_contains "src/service-a/internal/private.go" "${RUN_STDERR}" "file outside nested allowlist should not be reported"
}

test_allowlist_root_file_patterns_do_not_match_nested_basenames() {
    local repo_root
    repo_root="$(make_tempdir)"

    write_file "${repo_root}/imports.yaml" 'imports:
'
    write_file "${repo_root}/.oss-allowlist" 'main.go
'
    write_file "${repo_root}/main.go" 'package main
'
    write_file "${repo_root}/src/main.go" 'package src
'

    run_checker "${repo_root}"

    assert_status 1 "${RUN_STATUS}" "root allowlisted file missing a header should fail"
    assert_contains "Checked 1 files." "${RUN_STDERR}" "root file pattern should not check nested basenames"
