    test_lists_only_repo_groups_when_requested
    test_skips_vendor_go_files_and_detects_helm_files_under_chart_roots
    test_accepts_valid_headers
    test_accepts_allowlisted_spdx_headers_only_in_matching_dir
    test_accepts_allowlisted_spdx_headers
    test_warns_and_skips_missing_allowlisted_dir
    test_skips_sonar_project_properties
    test_sorts_reported_paths_with_c_locale_order
    test_skips_files_outside_oss_allowlists
    test_nested_oss_allowlists_are_relative_to_their_directory
    test_allowlist_root_file_patterns_do_not_match_nested_basenames
    test_warns_for_unsupported_oss_allowlist_negation_patterns
    echo "PASS: test-check-license-headers"
}

main "$@"
