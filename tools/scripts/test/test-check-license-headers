test_warns_for_unsupported_oss_allowlist_negation_patterns() {
    local repo_root
    repo_root="$(make_tempdir)"

    write_file "${repo_root}/imports.yaml" 'imports:
'
    write_file "${repo_root}/.oss-allowlist" 'tools/**
!tools/excluded.go
'
    write_file "${repo_root}/tools/excluded.go" 'package tools
'

    run_checker "${repo_root}"

    assert_status 1 "${RUN_STATUS}" "negation pattern should not suppress an included file"
    assert_contains "WARNING: negation patterns are not supported in .oss-allowlist (${repo_root}/.oss-allowlist: !tools/excluded.go)" "${RUN_STDERR}" "unsupported negation should warn"
    assert_contains "  - tools/excluded.go" "${RUN_STDERR}" "file matched by positive pattern should still be reported"
}

main() {
