test_skips_sonar_project_properties() {
    local repo_root
    repo_root="$(make_tempdir)"

    write_file "${repo_root}/imports.yaml" 'imports:
'
    write_file "${repo_root}/.oss-allowlist" 'tools/**
'
    write_file "${repo_root}/tools/sonar-project.properties" 'sonar.projectKey=test
'
    write_file "${repo_root}/tools/application.properties" 'app.name=test
'

    run_checker "${repo_root}"

    assert_status 1 "${RUN_STATUS}" "missing properties header should fail"
    assert_contains "Checked 1 files." "${RUN_STDERR}" "sonar-project.properties should be skipped"
    assert_contains "  - tools/application.properties" "${RUN_STDERR}" "application.properties should be reported"
    assert_not_contains "sonar-project.properties" "${RUN_STDERR}" "sonar-project.properties should not be reported"
}

test_sorts_reported_paths_with_c_locale_order() {
    local repo_root
    repo_root="$(make_tempdir)"

    write_file "${repo_root}/imports.yaml" 'imports:
'
    write_file "${repo_root}/.oss-allowlist" 'tools/**
'
    write_file "${repo_root}/tools/api/auth.go" 'package api
'
    write_file "${repo_root}/tools/api/auth/approle.go" 'package auth
'

    run_checker "${repo_root}" tools

    assert_status 1 "${RUN_STATUS}" "missing headers should fail for ordered path test"
    assert_order \
        "  - tools/api/auth.go" \
        "  - tools/api/auth/approle.go" \
        "${RUN_STDERR}" \
        "reported file paths should use deterministic C-locale ordering"
}

test_skips_files_outside_oss_allowlists() {
    local repo_root
    repo_root="$(make_tempdir)"

    write_file "${repo_root}/imports.yaml" 'imports:
'
    write_file "${repo_root}/.oss-allowlist" 'tools/**
'
    write_file "${repo_root}/tools/helper.py" "print('hi')"$'\n'
    write_file "${repo_root}/internal/private.go" 'package internal
'

    run_checker "${repo_root}"

    assert_status 1 "${RUN_STATUS}" "allowlisted file missing a header should fail"
    assert_contains "Checked 1 files." "${RUN_STDERR}" "only allowlisted source files should be checked"
    assert_contains "  - tools/helper.py" "${RUN_STDERR}" "allowlisted file should be reported"
    assert_not_contains "internal/private.go" "${RUN_STDERR}" "non-allowlisted file should not be reported"
